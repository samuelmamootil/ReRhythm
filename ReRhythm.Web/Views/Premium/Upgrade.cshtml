    <script>
      function upgradeTo(tier) {
        const userId = prompt(`Enter your User ID to upgrade to ${tier}:`);
        if (userId) {
          upgradeUser(userId, tier);
        }
      }

      async function upgradeUser(userId, tier) {
        const response = await fetch('@Url.Action("UpgradeUser")', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ userId, tier })
        });
        
        const result = await response.json();
        if (result.success) {
          alert('✅ ' + result.message + '\n\nRefresh the page to see your new badge!');
        } else {
          alert('❌ ' + result.error);
        }
      }

    </script>

