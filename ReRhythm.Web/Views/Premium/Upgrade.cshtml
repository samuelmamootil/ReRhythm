    <!-- Manual Upgrade (Demo Only) -->
    <div class="glass-card rounded-2xl p-8 mb-12 border-2 border-yellow-500/30">
      <h2 class="text-2xl font-bold text-white mb-4">🎯 Demo: Manual Upgrade</h2>
      <p class="text-slate-400 mb-4">For demonstration purposes, enter your User ID to upgrade to Gold tier:</p>
      
      <form id="upgradeForm" class="flex gap-3">
        <input type="text" id="userIdInput" placeholder="Enter your User ID" required
               class="flex-1 bg-slate-800/60 border border-slate-700 rounded-xl px-4 py-3 text-white
                      focus:outline-none focus:border-sky-500" />
        <button type="submit" class="bg-gradient-to-r from-yellow-400 to-orange-500 text-black px-8 py-3 rounded-xl font-bold hover:opacity-90">
          Upgrade Now
        </button>
      </form>
      <p class="text-xs text-slate-500 mt-3">Note: This is a demo feature. In production, this would be handled by payment gateway.</p>
    </div>

    <script>
      document.getElementById('upgradeForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const userId = document.getElementById('userIdInput').value;
        const btn = e.target.querySelector('button');
        btn.disabled = true;
        btn.textContent = 'Upgrading...';
        
        const response = await fetch('@Url.Action("UpgradeUser")', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ userId })
        });
        
        const result = await response.json();
        if (result.success) {
          alert('✅ ' + result.message + '\n\nRefresh the page to see your Gold badge!');
          document.getElementById('userIdInput').value = '';
        } else {
          alert('❌ ' + result.error);
        }
        
        btn.disabled = false;
        btn.textContent = 'Upgrade Now';
      });
    </script>

