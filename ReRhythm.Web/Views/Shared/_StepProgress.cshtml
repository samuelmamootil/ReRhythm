@model (string UserId, int ActiveStep)

<div class="flex items-center justify-center gap-0 mb-10 px-4">
  @{
    var steps = new[] {
      ("Upload Resume", "Upload", "Resume"),
      ("Skill Analysis", "Analysis", "Resume"),
      ("28-Day Roadmap", "Index", "Roadmap"),
      ("Lessons & Milestones", "Tracker", "Roadmap")
    };
  }
  @for (int i = 0; i < steps.Length; i++)
  {
    bool active = (i + 1) == Model.ActiveStep;
    bool clickable = !string.IsNullOrEmpty(Model.UserId) && i < Model.ActiveStep;
    var (label, action, controller) = steps[i];
    
    <div class="flex items-center">
      <div class="flex flex-col items-center">
        @if (clickable)
        {
          <a asp-controller="@controller" asp-action="@action" asp-route-userId="@Model.UserId"
             class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold
                    border-2 border-slate-600 text-slate-500 hover:border-sky-400 hover:text-sky-400 transition-colors">
            @(i + 1)
          </a>
        }
        else
        {
          <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold
                      border-2 @(active ? "border-sky-400 bg-sky-400/20 text-sky-400"
                                        : "border-slate-600 text-slate-500")">
            @(i + 1)
          </div>
        }
        <span class="text-xs mt-1 @(active ? "text-sky-400" : "text-slate-500")
                     whitespace-nowrap">
          @label
        </span>
      </div>
      @if (i < steps.Length - 1)
      {
        <div class="w-20 h-px mx-2 mb-4 bg-slate-700"></div>
      }
    </div>
  }
</div>
