@model string

@if (Model == "Gold")
{
    <span class="premium-badge" style="background: linear-gradient(135deg, #FFD700, #FFA500); color: #000; padding: 4px 12px; border-radius: 12px; font-size: 11px; font-weight: 600; margin-left: 8px;">
        ⭐ GOLD
    </span>
}
else
{
    <a href="@Url.Action("Upgrade", "Premium")" class="upgrade-btn" style="background: linear-gradient(135deg, #FFD700, #FFA500); color: #000; padding: 6px 16px; border-radius: 16px; font-size: 12px; font-weight: 600; text-decoration: none; margin-left: 12px; display: inline-block;">
        ⭐ Upgrade to Gold
    </a>
}
