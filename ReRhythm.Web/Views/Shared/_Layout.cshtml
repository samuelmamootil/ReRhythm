<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - ReRhythm</title>
  <link rel="icon" type="image/svg+xml" href="~/rhythmlogo.svg" />
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="~/css/site.css" />
  <style>
    body { background: #0a0e1a; transition: background-color 0.3s ease; }
    body.light-mode { background: #f8fafc; }
    body.light-mode .text-white { color: #0f172a !important; }
    body.light-mode h1, body.light-mode h2, body.light-mode h3, body.light-mode h4 { color: #0f172a !important; }
    body.light-mode .text-slate-400 { color: #475569 !important; }
    body.light-mode .text-slate-300 { color: #334155 !important; }
    body.light-mode .text-slate-500 { color: #64748b !important; }
    body.light-mode .text-sky-400 { color: #0284c7 !important; }
    body.light-mode .text-sky-300 { color: #0369a1 !important; }
    body.light-mode .text-emerald-400 { color: #059669 !important; }
    body.light-mode .text-red-300 { color: #dc2626 !important; }
    body.light-mode .bg-slate-800 { background-color: #e2e8f0 !important; }
    body.light-mode .bg-slate-800\/60 { background-color: rgba(226, 232, 240, 0.6) !important; }
    body.light-mode .bg-slate-800\/50 { background-color: rgba(226, 232, 240, 0.5) !important; }
    body.light-mode .bg-slate-800\/40 { background-color: rgba(226, 232, 240, 0.4) !important; }
    body.light-mode .bg-sky-500\/20 { background-color: rgba(14, 165, 233, 0.15) !important; }
    body.light-mode .bg-sky-500\/10 { background-color: rgba(14, 165, 233, 0.1) !important; }
    body.light-mode .bg-sky-500\/5 { background-color: rgba(14, 165, 233, 0.05) !important; }
    body.light-mode .border-slate-700 { border-color: #cbd5e1 !important; }
    body.light-mode .border-slate-600 { border-color: #cbd5e1 !important; }
    body.light-mode .border-slate-800 { border-color: #cbd5e1 !important; }
    body.light-mode .border-sky-500 { border-color: #0284c7 !important; }
    body.light-mode .glass-card { background: rgba(255, 255, 255, 0.9) !important; border: 1px solid #cbd5e1 !important; }
    body.light-mode nav { background: rgba(248, 250, 252, 0.95) !important; }
    body.light-mode .hero-bg { background: radial-gradient(ellipse at 50% 0%, rgba(14, 165, 233, 0.08) 0%, transparent 70%); }
    .gradient-text {
      background: linear-gradient(135deg, #ffffff 0%, #38bdf8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    body.light-mode .gradient-text {
      background: linear-gradient(135deg, #0f172a 0%, #0ea5e9 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .beat-text { color: #38bdf8; }
    body.light-mode .beat-text { color: #0ea5e9; }
    .re-text { color: white; }
    body.light-mode .re-text { color: black; }
    
    /* Button theme adjustments */
    body.light-mode .bg-slate-600 { background-color: #475569 !important; }
    body.light-mode .bg-slate-700 { background-color: #334155 !important; }
    body.light-mode .hover\:bg-slate-500:hover { background-color: #64748b !important; }
    body.light-mode .hover\:bg-slate-600:hover { background-color: #475569 !important; }
    body.light-mode .bg-sky-500 { background-color: #0ea5e9 !important; }
    body.light-mode .hover\:bg-sky-600:hover { background-color: #0284c7 !important; }
    body.light-mode .bg-emerald-600 { background-color: #059669 !important; }
    body.light-mode .hover\:bg-emerald-500:hover { background-color: #10b981 !important; }
    body.light-mode .border-slate-500 { border-color: #64748b !important; }
    body.light-mode .border-emerald-500 { border-color: #10b981 !important; }
    
    /* WCAG AA Compliant Button Styles */
    .bg-slate-600 { background-color: #0ea5e9 !important; color: white !important; }
    .bg-slate-700 { background-color: #0284c7 !important; color: white !important; }
    .bg-slate-800 { background-color: #0c4a6e !important; color: white !important; }
    .bg-slate-800\/60 { background-color: rgba(12, 74, 110, 0.6) !important; color: white !important; }
    .bg-slate-800\/50 { background-color: rgba(12, 74, 110, 0.5) !important; color: white !important; }
    .bg-slate-800\/40 { background-color: rgba(12, 74, 110, 0.4) !important; color: white !important; }
    .hover\:bg-slate-600:hover { background-color: #0284c7 !important; }
    .hover\:bg-slate-700:hover { background-color: #0c4a6e !important; }
    .hover\:bg-slate-700\/60:hover { background-color: rgba(12, 74, 110, 0.6) !important; }
    .hover\:bg-slate-800:hover { background-color: #075985 !important; }
    
    /* Light mode overrides for buttons */
    body.light-mode .bg-slate-600 { background-color: #0ea5e9 !important; color: white !important; }
    body.light-mode .bg-slate-700 { background-color: #0284c7 !important; color: white !important; }
    body.light-mode .bg-slate-800 { background-color: #0c4a6e !important; color: white !important; }
    body.light-mode .bg-slate-800\/60 { background-color: rgba(14, 165, 233, 0.3) !important; color: #0f172a !important; }
    body.light-mode .bg-slate-800\/50 { background-color: rgba(14, 165, 233, 0.25) !important; color: #0f172a !important; }
    body.light-mode .bg-slate-800\/40 { background-color: rgba(14, 165, 233, 0.2) !important; color: #0f172a !important; }
    .glass-card {
      background: rgba(15, 23, 42, 0.85);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(56, 189, 248, 0.15);
    }
    .glow-btn {
      background: linear-gradient(135deg, #0ea5e9, #6366f1);
      box-shadow: 0 0 20px rgba(14, 165, 233, 0.4);
      transition: all 0.3s ease;
    }
    .glow-btn:hover {
      box-shadow: 0 0 35px rgba(14, 165, 233, 0.7);
      transform: translateY(-1px);
    }
    .step-line {
      background: linear-gradient(90deg, #38bdf8, #6366f1);
    }
    .nav-logo-icon {
      background: linear-gradient(135deg, #0ea5e9, #6366f1);
      border-radius: 10px;
      padding: 6px;
    }
    .hero-bg {
      background: radial-gradient(ellipse at 50% 0%, rgba(56,189,248,0.08) 0%, transparent 70%);
    }
    @@keyframes shake {
      0%, 100% { transform: translateX(0); }
      10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
      20%, 40%, 60%, 80% { transform: translateX(5px); }
    }
    .animate-shake {
      animation: shake 0.5s;
    }
    
    /* Dropdown option styling for proper contrast */
    select option {
      background-color: #1e293b;
      color: #ffffff;
    }
    body.light-mode select option {
      background-color: #ffffff;
      color: #0f172a;
    }
  </style>
</head>
<body class="text-white antialiased min-h-screen">

  <!-- Navbar -->
  <nav class="border-b border-slate-800 px-4 sm:px-8 py-3 flex items-center justify-between
              sticky top-0 z-50"
       style="background: rgba(10,14,26,0.95); backdrop-filter: blur(10px);">
    <a asp-controller="Resume" asp-action="Upload" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
      <img src="~/rhythmlogo.svg" alt="ReRhythm Logo" class="w-8 h-8" />
      <span class="text-lg sm:text-xl font-bold"><span class="re-text">Re</span><span style="color: #38BDF8;">Rhythm</span></span>
    </a>
    
    <!-- Mobile Menu Button -->
    <button id="mobileMenuBtn" class="md:hidden text-slate-400 hover:text-white p-2">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
    
    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center gap-4 lg:gap-6 text-sm">
      <a href="/Home/Education" class="text-slate-400 hover:text-white transition-colors">Education</a>
      @if (ViewBag.SubscriptionTier == null || ViewBag.SubscriptionTier == "Gold")
      {
        <a href="/Premium/Upgrade" class="text-slate-400 hover:text-white transition-colors">Plans</a>
      }
      <a id="trackMilestonesLink" href="/Roadmap/FindUser" class="text-slate-400 hover:text-white transition-colors">Track Milestone</a>
      <a id="communityLink" href="/Community/Index" class="text-slate-400 hover:text-white transition-colors">Community</a>
      @if (ViewBag.SubscriptionTier == "Gold")
      {
        <a id="simulatorLink" href="/Simulator/Index" class="text-slate-400 hover:text-white transition-colors">Simulator</a>
        <a id="insightsLink" href="/Insights/Dashboard" class="text-slate-400 hover:text-white transition-colors">Insights</a>
      }
      
      @if (ViewContext.RouteData.Values["controller"]?.ToString() == "Community" || ViewContext.RouteData.Values["controller"]?.ToString() == "Forum")
      {
        @if (ViewBag.UserId != null && !string.IsNullOrEmpty(ViewBag.UserId))
        {
          <button onclick="toggleNotifications()" class="relative text-slate-400 hover:text-white transition-colors p-2 rounded-lg hover:bg-slate-800">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>
            <span id="navNotifBadge" class="hidden absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center"></span>
          </button>
        }
      }
      
      @if (ViewBag.SubscriptionTier == "Gold")
      {
        <span style="background: linear-gradient(135deg, #FFD700, #FFA500); color: #000; padding: 4px 12px; border-radius: 12px; font-size: 11px; font-weight: 600;">⭐ GOLD</span>
      }
      else if (ViewBag.SubscriptionTier != null)
      {
        <a href="/Premium/Upgrade" style="background: linear-gradient(135deg, #FFD700, #FFA500); color: #000; padding: 6px 16px; border-radius: 16px; font-size: 12px; font-weight: 600; text-decoration: none;">⭐ Upgrade</a>
      }
      
      <button id="themeToggle" class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-offset-2" aria-label="Toggle theme">
        <span class="sr-only">Toggle theme</span>
        <span id="toggleBg" class="inline-block h-6 w-11 rounded-full bg-slate-700 transition-colors"></span>
        <span id="toggleCircle" class="absolute left-0.5 inline-block h-5 w-5 transform rounded-full bg-white shadow-lg transition-transform translate-x-0">
          <svg id="darkIcon" class="w-3 h-3 m-1 text-slate-700" fill="currentColor" viewBox="0 0 20 20">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
          </svg>
          <svg id="lightIcon" class="w-3 h-3 m-1 text-amber-500 hidden" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/>
          </svg>
        </span>
      </button>
    </div>
  </nav>
  
  <!-- Mobile Menu -->
  <div id="mobileMenu" class="hidden md:hidden fixed inset-0 bg-gray-950/95 z-50">
    <div class="flex flex-col h-full">
      <div class="flex items-center justify-between p-4 border-b border-slate-800">
        <div class="flex items-center gap-2">
          <img src="~/rhythmlogo.svg" alt="ReRhythm Logo" class="w-8 h-8" />
          <span class="text-xl font-bold"><span class="re-text">Re</span><span style="color: #38BDF8;">Rhythm</span></span>
        </div>
        <button id="closeMobileMenu" class="text-slate-400 hover:text-white p-2">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="flex-1 overflow-y-auto p-4">
        <div class="space-y-4">
          @if (ViewBag.SubscriptionTier == "Gold")
          {
            <div class="text-center py-2">
              <span style="background: linear-gradient(135deg, #FFD700, #FFA500); color: #000; padding: 8px 20px; border-radius: 16px; font-size: 14px; font-weight: 600;">⭐ GOLD MEMBER</span>
            </div>
          }
          else if (ViewBag.SubscriptionTier != null)
          {
            <a href="/Premium/Upgrade" class="block text-center py-3 rounded-xl" style="background: linear-gradient(135deg, #FFD700, #FFA500); color: #000; font-weight: 600;">
              ⭐ Upgrade to Gold
            </a>
          }
          <a href="/Home/Education" class="block p-4 bg-slate-800/60 rounded-xl text-white hover:bg-slate-700/60 transition-colors">Education</a>
          @if (ViewBag.SubscriptionTier == null || ViewBag.SubscriptionTier == "Gold")
          {
            <a href="/Premium/Upgrade" class="block p-4 bg-slate-800/60 rounded-xl text-white hover:bg-slate-700/60 transition-colors">Plans</a>
          }
          <a id="mobileTrackLink" href="/Roadmap/FindUser" class="block p-4 bg-slate-800/60 rounded-xl text-white hover:bg-slate-700/60 transition-colors">Track Milestone</a>
          <a id="mobileCommunityLink" href="/Community/Index" class="block p-4 bg-slate-800/60 rounded-xl text-white hover:bg-slate-700/60 transition-colors">Community</a>
          @if (ViewBag.SubscriptionTier == "Gold")
          {
            <a id="mobileSimulatorLink" href="/Simulator/Index" class="block p-4 bg-slate-800/60 rounded-xl text-white hover:bg-slate-700/60 transition-colors">Simulator</a>
            <a id="mobileInsightsLink" href="/Insights/Dashboard" class="block p-4 bg-slate-800/60 rounded-xl text-white hover:bg-slate-700/60 transition-colors">Insights</a>
          }
          
          <div class="flex items-center justify-between p-4 bg-slate-800/60 rounded-xl">
            <span class="text-white font-medium">Theme</span>
            <button id="mobileThemeToggle" class="relative inline-flex h-7 w-12 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-sky-500" aria-label="Toggle theme">
              <span class="sr-only">Toggle theme</span>
              <span id="mobileToggleBg" class="inline-block h-7 w-12 rounded-full bg-slate-700 transition-colors"></span>
              <span id="mobileToggleCircle" class="absolute left-0.5 inline-block h-6 w-6 transform rounded-full bg-white shadow-lg transition-transform translate-x-0">
                <span id="mobileDarkIcon" class="block text-xl leading-6 text-center">🌙</span>
                <span id="mobileLightIcon" class="hidden text-xl leading-6 text-center">☀️</span>
              </span>
            </button>
          </div>
          
          <div class="text-center text-xs text-slate-500 pt-4">Powered by AWS Bedrock</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Mobile menu toggle
    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    const closeMobileMenu = document.getElementById('closeMobileMenu');
    
    if (mobileMenuBtn) {
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenu.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });
    }
    
    if (closeMobileMenu) {
      closeMobileMenu.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        document.body.style.overflow = '';
      });
    }
    
    // Theme toggle
    const themeToggle = document.getElementById('themeToggle');
    const mobileThemeToggle = document.getElementById('mobileThemeToggle');
    const darkIcon = document.getElementById('darkIcon');
    const lightIcon = document.getElementById('lightIcon');
    const mobileDarkIcon = document.getElementById('mobileDarkIcon');
    const mobileLightIcon = document.getElementById('mobileLightIcon');
    const savedTheme = localStorage.getItem('theme') || 'dark';
    
    function updateThemeIcons(isLight) {
      const toggleBg = document.getElementById('toggleBg');
      const toggleCircle = document.getElementById('toggleCircle');
      const mobileToggleBg = document.getElementById('mobileToggleBg');
      const mobileToggleCircle = document.getElementById('mobileToggleCircle');
      
      if (darkIcon) darkIcon.classList.toggle('hidden', isLight);
      if (lightIcon) lightIcon.classList.toggle('hidden', !isLight);
      if (mobileDarkIcon) mobileDarkIcon.classList.toggle('hidden', isLight);
      if (mobileLightIcon) mobileLightIcon.classList.toggle('hidden', !isLight);
      
      if (toggleBg) toggleBg.style.backgroundColor = isLight ? '#38bdf8' : '#334155';
      if (toggleCircle) toggleCircle.style.transform = isLight ? 'translateX(1.25rem)' : 'translateX(0)';
      if (mobileToggleBg) mobileToggleBg.style.backgroundColor = isLight ? '#38bdf8' : '#334155';
      if (mobileToggleCircle) mobileToggleCircle.style.transform = isLight ? 'translateX(1.25rem)' : 'translateX(0)';
    }
    
    if (savedTheme === 'light') {
      document.body.classList.add('light-mode');
      updateThemeIcons(true);
    }
    
    function toggleTheme() {
      document.body.classList.toggle('light-mode');
      const isLight = document.body.classList.contains('light-mode');
      localStorage.setItem('theme', isLight ? 'light' : 'dark');
      updateThemeIcons(isLight);
    }
    
    if (themeToggle) themeToggle.addEventListener('click', toggleTheme);
    if (mobileThemeToggle) mobileThemeToggle.addEventListener('click', toggleTheme);

    // Update navigation links if userId exists
    const urlParams = new URLSearchParams(window.location.search);
    const currentUserId = urlParams.get('userId');
    const isUploadPage = window.location.pathname === '/Resume/Upload' || window.location.pathname === '/';
    const isFindUserPage = window.location.pathname === '/Roadmap/FindUser';
    
    if (currentUserId) {
      localStorage.setItem('reRhythmLastUserId', currentUserId);
      const communityLink = document.getElementById('communityLink');
      const simulatorLink = document.getElementById('simulatorLink');
      const insightsLink = document.getElementById('insightsLink');
      const mobileCommunityLink = document.getElementById('mobileCommunityLink');
      const mobileSimulatorLink = document.getElementById('mobileSimulatorLink');
      const mobileInsightsLink = document.getElementById('mobileInsightsLink');
      const trackLink = document.getElementById('trackMilestonesLink');
      const mobileTrackLink = document.getElementById('mobileTrackLink');
      
      if (communityLink) communityLink.href = `/Community/Index?userId=${currentUserId}`;
      if (simulatorLink) simulatorLink.href = `/Simulator/Index?userId=${currentUserId}`;
      if (insightsLink) insightsLink.href = `/Insights/Dashboard?userId=${currentUserId}`;
      if (mobileCommunityLink) mobileCommunityLink.href = `/Community/Index?userId=${currentUserId}`;
      if (mobileSimulatorLink) mobileSimulatorLink.href = `/Simulator/Index?userId=${currentUserId}`;
      if (mobileInsightsLink) mobileInsightsLink.href = `/Insights/Dashboard?userId=${currentUserId}`;
      if (trackLink) trackLink.style.display = 'none';
      if (mobileTrackLink) mobileTrackLink.style.display = 'none';
    }
    
    // Hide Track Milestone on upload page and find user page
    if (isUploadPage || isFindUserPage) {
      const trackLink = document.getElementById('trackMilestonesLink');
      const mobileTrackLink = document.getElementById('mobileTrackLink');
      if (trackLink) trackLink.style.display = 'none';
      if (mobileTrackLink) mobileTrackLink.style.display = 'none';
    }
  </script>

  <main>@RenderBody()</main>

  <footer class="border-t border-slate-800 py-4 text-center">
    <p class="text-xs text-slate-500">Powered by AWS Bedrock</p>
  </footer>

  <script src="~/js/site.js" defer></script>
  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
