@model ReRhythm.Core.Services.RoadmapPlan
@{
    ViewData["Title"] = "Your Achievements";
    var completedCount = ViewBag.CompletedCount;
    var totalLessons = ViewBag.TotalLessons;
    var progressPercent = ViewBag.ProgressPercent;
}

<div class="hero-bg min-h-screen px-6 py-10">

  <!-- Hero Header -->
  <div class="text-center pt-10 pb-6 px-4">
    <div class="flex justify-center">
      <img src="~/rhythmlogo.png" alt="ReRhythm Logo" class="h-32 page-logo m-0 p-0" />
    </div>
    <h1 class="text-4xl font-extrabold mb-2 leading-tight">
      Your <span class="beat-text">Achievements</span>
    </h1>
    <p class="text-slate-400 text-lg max-w-2xl mx-auto">
      Track your progress and share your milestones
    </p>
  </div>

  <!-- Step Progress Bar -->
  <partial name="_StepProgress" model="(Model.UserId, 4)" />

  <!-- Header -->
  <div class="max-w-6xl mx-auto mb-8">
    <div class="flex items-center justify-between mb-6">
      <a asp-controller="Roadmap" asp-action="Tracker" asp-route-userId="@Model.UserId"
         class="text-slate-400 hover:text-white transition-colors">
        ← Back to Tracker
      </a>
    </div>
  </div>

  <!-- Progress Overview -->
  <div class="max-w-6xl mx-auto mb-12">
    <div class="glass-card rounded-2xl p-8 border border-slate-700">
      <div class="grid md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-5xl font-bold text-sky-400 mb-2">@progressPercent%</div>
          <div class="text-slate-400 text-sm">Progress</div>
        </div>
        <div class="text-center">
          <div class="text-5xl font-bold text-sky-400 mb-2">@completedCount</div>
          <div class="text-slate-400 text-sm">Lessons Done</div>
        </div>
        <div class="text-center">
          <div class="text-5xl font-bold text-emerald-400 mb-2" id="badgeCount">0</div>
          <div class="text-slate-400 text-sm">Badges Earned</div>
        </div>
        <div class="text-center">
          <div class="text-5xl font-bold text-purple-400 mb-2">@(Model.Modules.Count(m => true))</div>
          <div class="text-slate-400 text-sm">Weeks Active</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Badges & Achievements -->
  <div class="max-w-6xl mx-auto mb-12">
    <h2 class="text-2xl font-bold mb-6 flex items-center gap-3 text-white">
      <span class="text-3xl">🏆</span> Badges & Milestones
    </h2>
    <div id="badgesContainer" class="grid md:grid-cols-3 gap-6">
      <!-- Badges will be loaded here -->
    </div>
  </div>

  <!-- Referral Section -->
  <div class="max-w-6xl mx-auto mb-12">
    <h2 class="text-2xl font-bold mb-6 flex items-center gap-3 text-white">
      <span class="text-3xl">🤝</span> Help Others Grow
    </h2>
    <div class="glass-card rounded-2xl p-8 border border-slate-700">
      <div class="text-center mb-6">
        <h3 class="text-xl font-semibold text-white mb-2">Share Your Learning Journey</h3>
        <p class="text-slate-400 text-sm max-w-2xl mx-auto">
          Know someone who could benefit from career development? Share ReRhythm with them. 
          Help others discover their path through ReRhythm.
        </p>
      </div>

      <div class="bg-slate-800/50 rounded-xl p-6 border border-slate-700 mb-6">
        <label class="block text-sm font-medium text-slate-300 mb-2">Your Referral Link</label>
        <div class="flex gap-2">
          <input type="text" id="referralLink" readonly
                 value="https://rerhythm.com?ref=@Model.UserId"
                 class="flex-1 bg-slate-800/60 border border-slate-700 rounded-xl px-4 py-3 text-white">
          <button onclick="copyReferralLink()"
                  class="px-6 py-3 bg-sky-500 hover:bg-sky-600 text-white font-semibold rounded-xl transition-colors">
            Copy
          </button>
        </div>
        <p class="text-xs text-slate-500 mt-2">Share this link with friends who might benefit from career coaching</p>
      </div>

      <div class="grid md:grid-cols-4 gap-4">
        <button onclick="shareToLinkedIn()"
                class="flex items-center justify-center gap-2 px-6 py-3 bg-[#0077b5] hover:bg-[#006399] text-white font-semibold rounded-xl transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </button>
        <button onclick="shareToTwitter()"
                class="flex items-center justify-center gap-2 px-6 py-3 bg-slate-700 hover:bg-slate-600 text-white font-semibold rounded-xl transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          X (Twitter)
        </button>
        <button onclick="shareToInstagram()"
                class="flex items-center justify-center gap-2 px-6 py-3 bg-gradient-to-r from-purple-500 via-pink-500 to-orange-500 hover:from-purple-600 hover:via-pink-600 hover:to-orange-600 text-white font-semibold rounded-xl transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          Instagram
        </button>
        <button onclick="shareViaEmail()"
                class="flex items-center justify-center gap-2 px-6 py-3 bg-slate-700 hover:bg-slate-600 text-white font-semibold rounded-xl transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Email
        </button>
      </div>
    </div>
  </div>

  <!-- Leaderboard (Optional) -->
  <div class="max-w-6xl mx-auto">
    <h2 class="text-2xl font-bold mb-6 flex items-center gap-3 text-white">
      <span class="text-3xl">📊</span> Your Standing
    </h2>
    <div class="glass-card rounded-2xl p-8 border border-slate-700">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 bg-slate-800/50 rounded-xl px-6 py-4 border border-slate-700">
          <div class="text-4xl">🎯</div>
          <div class="text-left">
            <div class="text-2xl font-bold text-sky-400">@progressPercent% Complete</div>
            <div class="text-sm text-slate-400">Keep going! You're making great progress</div>
          </div>
        </div>
        <p class="text-slate-500 text-sm mt-6">
          Focus on your own growth journey. Compare yourself to who you were yesterday, not to others today.
        </p>
      </div>
    </div>
  </div>

</div>

<script>
  const userId = '@Model.UserId';
  const targetRole = '@Model.TargetRole';
  const completedCount = @completedCount;
  const totalLessons = @totalLessons;
  const progressPercent = @progressPercent;

  // Badge definitions with unlock requirements
  const badges = [
    { id: 'first-step', name: 'First Step', icon: '🚀', description: 'Completed your first lesson', requirement: 'Complete 1 lesson', unlocked: completedCount >= 1 },
    { id: 'week-warrior', name: 'Week Warrior', icon: '⚡', description: 'Completed 7 lessons', requirement: 'Complete 7 lessons', unlocked: completedCount >= 7 },
    { id: 'halfway-hero', name: 'Halfway Hero', icon: '🎯', description: 'Reached 50% completion', requirement: 'Reach 50% progress', unlocked: progressPercent >= 50 },
    { id: 'sprint-master', name: 'Sprint Master', icon: '🏃', description: 'Completed 21 lessons', requirement: 'Complete 21 lessons', unlocked: completedCount >= 21 },
    { id: 'graduate', name: 'Graduate', icon: '🎓', description: 'Completed all 28 lessons', requirement: 'Complete all 28 lessons', unlocked: progressPercent >= 100 },
    { id: 'skill-builder', name: 'Skill Builder', icon: '🛠️', description: 'Acquired 5+ new skills', requirement: 'Complete 14 lessons', unlocked: completedCount >= 14 }
  ];

  function renderBadges() {
    const container = document.getElementById('badgesContainer');
    const earnedCount = badges.filter(b => b.unlocked).length;
    document.getElementById('badgeCount').textContent = earnedCount;

    container.innerHTML = badges.map(badge => {
      const progress = getProgress(badge);
      return `
      <div class="glass-card rounded-2xl p-6 border ${badge.unlocked ? 'border-sky-500' : 'border-slate-700'} transition-all duration-300 ${badge.unlocked ? '' : 'opacity-50'}">
        <div class="text-center">
          <div class="text-6xl mb-4 ${badge.unlocked ? 'animate-bounce' : 'grayscale'}">${badge.icon}</div>
          <h3 class="text-lg font-bold text-white mb-2">${badge.name}</h3>
          <p class="text-sm text-slate-400 mb-4">${badge.description}</p>
          ${badge.unlocked ? `
            <div class="text-sm text-emerald-400 flex items-center justify-center gap-1 mb-3">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Unlocked
            </div>
            <button onclick="shareBadge('${badge.id}', '${badge.name}', '${badge.icon}')"
                    class="w-full px-4 py-2 bg-sky-500 hover:bg-sky-600 text-white text-sm font-semibold rounded-lg transition-colors flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
              </svg>
              Share Badge
            </button>
          ` : `
            <div class="mb-3">
              <div class="text-xs text-slate-400 mb-2">${badge.requirement}</div>
              <div class="w-full bg-slate-800 rounded-full h-2 overflow-hidden">
                <div class="bg-sky-500 h-2 rounded-full transition-all duration-500" style="width: ${progress}%"></div>
              </div>
              <div class="text-xs text-slate-500 mt-1">${progress}% complete</div>
            </div>
            <div class="text-xs text-slate-500 flex items-center justify-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
              Locked
            </div>
          `}
        </div>
      </div>
    `}).join('');
  }

  function getProgress(badge) {
    switch(badge.id) {
      case 'first-step':
        return Math.min(100, (completedCount / 1) * 100);
      case 'week-warrior':
        return Math.min(100, (completedCount / 7) * 100);
      case 'halfway-hero':
        return Math.min(100, progressPercent * 2);
      case 'sprint-master':
        return Math.min(100, (completedCount / 21) * 100);
      case 'graduate':
        return progressPercent;
      case 'skill-builder':
        return Math.min(100, (completedCount / 14) * 100);
      default:
        return 0;
    }
  }

  function shareBadge(badgeId, badgeName, badgeIcon) {
    const text = `Just earned the "${badgeName}" ${badgeIcon} badge on ReRhythm!\n\nI'm ${progressPercent}% through my 28-day ${targetRole} career development journey.\n\nCheck it out: https://rerhythm.com?ref=${userId}`;
    
    if (navigator.share) {
      navigator.share({ text });
    } else {
      const linkedInUrl = `https://www.linkedin.com/feed/?shareActive=true&text=${encodeURIComponent(text)}`;
      window.open(linkedInUrl, '_blank', 'width=600,height=700');
    }
  }

  function copyReferralLink() {
    const input = document.getElementById('referralLink');
    input.select();
    document.execCommand('copy');
    
    const btn = event.target;
    const originalText = btn.textContent;
    btn.textContent = 'Copied!';
    btn.classList.add('bg-emerald-500');
    setTimeout(() => {
      btn.textContent = originalText;
      btn.classList.remove('bg-emerald-500');
    }, 2000);
  }

  function shareToLinkedIn() {
    const text = `I'm using ReRhythm for my ${targetRole} career development—28 days of focused learning with AWS-powered coaching.\n\nIf you're looking to upskill or transition roles, check it out: https://rerhythm.com?ref=${userId}`;
    const linkedInUrl = `https://www.linkedin.com/feed/?shareActive=true&text=${encodeURIComponent(text)}`;
    window.open(linkedInUrl, '_blank', 'width=600,height=700');
  }

  function shareToTwitter() {
    const text = `Leveling up my career with ReRhythm—AI-powered 28-day roadmap for ${targetRole}. Check it out: https://rerhythm.com?ref=${userId}`;
    const twitterUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`;
    window.open(twitterUrl, '_blank', 'width=600,height=400');
  }

  function shareToInstagram() {
    const text = `Leveling up my career with ReRhythm—AI-powered 28-day roadmap for ${targetRole}. Link in bio: rerhythm.com?ref=${userId}`;
    
    if (navigator.share) {
      navigator.share({
        title: 'ReRhythm Career Development',
        text: text
      }).catch(err => console.log('Share cancelled'));
    } else {
      // Fallback: copy text to clipboard
      navigator.clipboard.writeText(text).then(() => {
        alert('Text copied! Open Instagram and paste in your story or post.');
      });
    }
  }

  function shareViaEmail() {
    const subject = 'Check out ReRhythm - AI Career Coaching';
    const body = `Hi,\n\nI've been using ReRhythm for my career development and thought you might find it helpful.\n\nIt's a 28-day AI-powered program that creates a personalized learning roadmap based on your resume and target role. The daily 15-minute lessons are really manageable and focused.\n\nHere's the link if you want to check it out: https://rerhythm.com?ref=${userId}\n\nNo pressure—just thought it might be useful for you!\n\nBest,`;
    window.location.href = `mailto:?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  }

  // Initialize
  renderBadges();
</script>
