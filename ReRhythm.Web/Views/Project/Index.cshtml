@model List<ReRhythm.Core.Models.Project>
@{
    ViewData["Title"] = "Project Showcase";
    var userId = ViewBag.UserId;
    var userName = ViewBag.UserName;
    var industry = ViewBag.Industry;
    var reputation = ViewBag.Reputation;
}

<div class="hero-bg min-h-screen">
  <div class="max-w-6xl mx-auto px-4 py-16">
    
    <div class="text-center mb-12">
      <h1 class="text-5xl font-extrabold mb-4">
        <span class="beat-text">Project Showcase</span>
      </h1>
      <p class="text-slate-400 text-lg">Share your work, get feedback, build reputation</p>
    </div>

    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-4">
        <div class="glass-card rounded-xl px-6 py-3 border border-yellow-500/50">
          <div class="flex items-center gap-2">
            <span class="text-2xl">⭐</span>
            <div>
              <div class="text-xl font-bold text-yellow-400">@reputation</div>
              <div class="text-xs text-slate-400">Reputation</div>
            </div>
          </div>
        </div>
      </div>
      <button onclick="showCreateModal()" class="glow-btn px-6 py-3 rounded-xl font-semibold flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M12 4v16m8-8H4"/>
        </svg>
        Share Project
      </button>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      @foreach (var project in Model)
      {
        <div class="glass-card rounded-xl overflow-hidden border border-slate-700 hover:border-sky-500/50 transition-colors">
          @if (project.ImageUrls.Any())
          {
            <div class="aspect-video bg-slate-800 overflow-hidden">
              <img src="@project.ImageUrls.First()" alt="@project.Title" class="w-full h-full object-cover" />
            </div>
          }
          else
          {
            <div class="aspect-video bg-gradient-to-br from-slate-800 to-slate-900 flex items-center justify-center">
              <span class="text-6xl">🚀</span>
            </div>
          }
          
          <div class="p-6">
            <h3 class="text-xl font-bold text-white mb-2">@project.Title</h3>
            <p class="text-slate-400 text-sm mb-3 line-clamp-2">@project.Description</p>
            
            <div class="flex items-center gap-2 mb-3">
              @foreach (var tech in project.TechStack.Split(',').Take(3))
              {
                <span class="bg-sky-500/20 text-sky-400 px-2 py-1 rounded text-xs">@tech.Trim()</span>
              }
            </div>

            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-3 text-xs text-slate-500">
                <span>@project.UserName</span>
                <span>•</span>
                <span>@project.ViewCount views</span>
              </div>
              <div class="flex items-center gap-1">
                <span class="text-yellow-400">★</span>
                <span class="text-white font-semibold">@project.AverageRating.ToString("F1")</span>
                <span class="text-slate-500 text-xs">(@project.ReviewCount)</span>
              </div>
            </div>

            <a href="@Url.Action("Details", new { id = project.ProjectId, userId })" 
               class="w-full bg-slate-700 hover:bg-slate-600 text-white font-semibold py-2 px-4 rounded-lg transition-colors block text-center">
              View Details
            </a>
          </div>
        </div>
      }
    </div>

    @if (!Model.Any())
    {
      <div class="text-center py-12">
        <div class="text-6xl mb-4">📂</div>
        <p class="text-slate-400 text-lg mb-4">No projects yet. Be the first to share!</p>
        <button onclick="showCreateModal()" class="glow-btn px-6 py-3 rounded-xl font-semibold inline-block">
          Share Your Project
        </button>
      </div>
    }

  </div>
</div>

<div id="createModal" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4 overflow-y-auto">
  <div class="glass-card rounded-2xl p-8 max-w-2xl w-full my-8">
    <h2 class="text-2xl font-bold text-white mb-6">Share Your Project</h2>
    
    <form id="createForm" enctype="multipart/form-data">
      <input type="hidden" name="userId" value="@userId" />
      
      <div class="mb-4">
        <label class="block text-slate-300 mb-2 font-semibold">Project Title</label>
        <input type="text" name="title" required maxlength="100"
               class="w-full bg-slate-800/60 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-sky-500" />
      </div>

      <div class="mb-4">
        <label class="block text-slate-300 mb-2 font-semibold">Description</label>
        <textarea name="description" required rows="4" maxlength="500"
                  class="w-full bg-slate-800/60 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-sky-500"></textarea>
      </div>

      <div class="mb-4">
        <label class="block text-slate-300 mb-2 font-semibold">Tech Stack (comma-separated)</label>
        <input type="text" name="techStack" required placeholder="React, Node.js, MongoDB"
               class="w-full bg-slate-800/60 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-sky-500" />
      </div>

      <div class="grid md:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-slate-300 mb-2 font-semibold">GitHub URL (optional)</label>
          <input type="url" name="githubUrl"
                 class="w-full bg-slate-800/60 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-sky-500" />
        </div>
        <div>
          <label class="block text-slate-300 mb-2 font-semibold">Live URL (optional)</label>
          <input type="url" name="liveUrl"
                 class="w-full bg-slate-800/60 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-sky-500" />
        </div>
      </div>

      <div class="mb-6">
        <label class="block text-slate-300 mb-2 font-semibold">Screenshots (Max 3)</label>
        <div id="projectDropZone" class="border-2 border-dashed border-slate-600 rounded-xl p-6 text-center cursor-pointer hover:border-sky-500 hover:bg-sky-500/5"
             onclick="document.getElementById('projectFileInput').click()">
          <div id="projectDropDefault">
            <div class="w-10 h-10 mx-auto mb-2 rounded-xl bg-slate-800 flex items-center justify-center">
              <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <p class="text-slate-300 font-medium text-sm">Drop images or click to browse</p>
          </div>
          <div id="projectDropSelected" class="hidden">
            <p id="projectFileNames" class="text-emerald-400 text-xs"></p>
          </div>
        </div>
        <input type="file" id="projectFileInput" name="images" accept="image/*" multiple style="display: none;" />
      </div>

      <div class="flex gap-3">
        <button type="submit" class="glow-btn px-6 py-3 rounded-xl font-semibold flex-1">Share Project</button>
        <button type="button" onclick="hideCreateModal()" class="bg-slate-700 hover:bg-slate-600 px-6 py-3 rounded-xl font-semibold text-white">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
  function showCreateModal() {
    document.getElementById('createModal').classList.remove('hidden');
  }

  function hideCreateModal() {
    document.getElementById('createModal').classList.add('hidden');
  }

  document.getElementById('createForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Sharing...';
    
    const formData = new FormData(e.target);
    const response = await fetch('@Url.Action("Create")', {
      method: 'POST',
      body: formData
    });
    
    const result = await response.json();
    if (result.success) {
      location.reload();
    } else {
      alert(result.error);
      btn.disabled = false;
      btn.textContent = 'Share Project';
    }
  });

  const projectFileInput = document.getElementById('projectFileInput');
  projectFileInput.addEventListener('change', () => {
    if (projectFileInput.files.length > 0) {
      const names = Array.from(projectFileInput.files).map(f => f.name).join(', ');
      document.getElementById('projectFileNames').textContent = names;
      document.getElementById('projectDropDefault').classList.add('hidden');
      document.getElementById('projectDropSelected').classList.remove('hidden');
    }
  });
</script>
