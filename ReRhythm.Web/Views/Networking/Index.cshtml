@model List<ReRhythm.Core.Models.UserProfile>
@{
    ViewData["Title"] = "Network";
    var userId = ViewBag.UserId;
    var userName = ViewBag.UserName;
    var industry = ViewBag.Industry;
    var targetRole = ViewBag.TargetRole;
    var connections = (List<string>)ViewBag.Connections;
    var pendingCount = ViewBag.PendingCount;
}

<div class="hero-bg min-h-screen">
  <div class="max-w-6xl mx-auto px-4 py-16">
    
    <div class="text-center mb-12">
      <h1 class="text-5xl font-extrabold mb-4">
        <span class="beat-text">Network</span>
      </h1>
      <p class="text-slate-400 text-lg">Connect with @targetRole professionals in @industry</p>
    </div>

    <div class="flex gap-4 mb-8">
      <a href="@Url.Action("Index", "Networking", new { userId })" class="glow-btn px-6 py-3 rounded-xl font-semibold">
        Browse Members
      </a>
      <a href="@Url.Action("Requests", "Networking", new { userId })" class="bg-slate-700 hover:bg-slate-600 px-6 py-3 rounded-xl font-semibold text-white relative">
        Connection Requests
        @if (pendingCount > 0)
        {
          <span class="absolute -top-2 -right-2 bg-red-500 text-white text-xs font-bold rounded-full w-6 h-6 flex items-center justify-center">@pendingCount</span>
        }
      </a>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      @foreach (var member in Model)
      {
        var isConnected = connections.Contains(member.UserId);
        var progress = member.TotalLessons > 0 ? (member.CompletedLessons * 100 / member.TotalLessons) : 0;
        
        <div class="glass-card rounded-xl p-6 border border-slate-700">
          <div class="flex items-start justify-between mb-4">
            <div>
              <h3 class="text-xl font-bold text-white mb-1">@member.Name</h3>
              <p class="text-sky-400 text-sm font-semibold">@member.TargetRole</p>
              <p class="text-slate-500 text-xs">@member.Industry</p>
            </div>
            <div class="text-right">
              <div class="text-2xl font-bold text-emerald-400">@progress%</div>
              <div class="text-xs text-slate-500">@member.CompletedLessons/@member.TotalLessons lessons</div>
            </div>
          </div>

          <div class="mb-4">
            <div class="bg-slate-800 rounded-full h-2 overflow-hidden">
              <div class="bg-gradient-to-r from-sky-500 to-emerald-500 h-full transition-all" style="width: @progress%"></div>
            </div>
          </div>

          <div class="flex items-center justify-between text-xs text-slate-500 mb-4">
            <span>Joined @member.JoinedAt.ToString("MMM yyyy")</span>
          </div>

          @if (isConnected)
          {
            <button disabled class="w-full bg-emerald-500/20 text-emerald-400 font-semibold py-3 px-4 rounded-xl cursor-not-allowed">
              ✓ Connected
            </button>
          }
          else
          {
            <button onclick="sendRequest('@member.UserId', '@member.Name')" class="w-full bg-sky-500 hover:bg-sky-600 text-white font-semibold py-3 px-4 rounded-xl transition-colors">
              Connect
            </button>
          }
        </div>
      }
    </div>

    @if (!Model.Any())
    {
      <div class="text-center py-12">
        <div class="text-6xl mb-4">🔍</div>
        <p class="text-slate-400 text-lg">No members found in your industry yet</p>
      </div>
    }

  </div>
</div>

<div id="requestModal" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4">
  <div class="glass-card rounded-2xl p-8 max-w-md w-full">
    <h2 class="text-2xl font-bold text-white mb-4">Send Connection Request</h2>
    <p class="text-slate-300 mb-6">to <span id="targetName" class="text-sky-400 font-semibold"></span></p>
    
    <form id="requestForm">
      <input type="hidden" id="targetUserId" />
      <textarea id="requestMessage" placeholder="Add a message (optional)" rows="3" maxlength="200"
                class="w-full bg-slate-800/60 border border-slate-700 rounded-xl px-4 py-3 text-white mb-4 focus:outline-none focus:border-sky-500"></textarea>
      
      <div class="flex gap-3">
        <button type="submit" class="glow-btn px-6 py-3 rounded-xl font-semibold flex-1">Send</button>
        <button type="button" onclick="hideRequestModal()" class="bg-slate-700 hover:bg-slate-600 px-6 py-3 rounded-xl font-semibold text-white">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
  function sendRequest(toUserId, toName) {
    document.getElementById('targetUserId').value = toUserId;
    document.getElementById('targetName').textContent = toName;
    document.getElementById('requestModal').classList.remove('hidden');
  }

  function hideRequestModal() {
    document.getElementById('requestModal').classList.add('hidden');
    document.getElementById('requestMessage').value = '';
  }

  document.getElementById('requestForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Sending...';
    
    const response = await fetch('@Url.Action("SendRequest")', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({
        fromUserId: '@userId',
        toUserId: document.getElementById('targetUserId').value,
        message: document.getElementById('requestMessage').value
      })
    });
    
    const result = await response.json();
    if (result.success) {
      hideRequestModal();
      location.reload();
    } else {
      alert(result.error);
      btn.disabled = false;
      btn.textContent = 'Send';
    }
  });
</script>
