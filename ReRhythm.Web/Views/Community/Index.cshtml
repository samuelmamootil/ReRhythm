@model List<ReRhythm.Core.Models.ForumQuestion>
@{
    ViewData["Title"] = "Community";
    var userId = ViewBag.UserId;
    var userName = ViewBag.UserName;
    var industry = ViewBag.Industry;
    var targetRole = ViewBag.TargetRole;
    var isGuest = ViewBag.IsGuest ?? false;
    var totalUsers = ViewBag.TotalUsers;
    var completedUsers = ViewBag.CompletedUsers;
    var referralCount = ViewBag.ReferralCount;
    var discountPercent = ViewBag.DiscountPercent;
    var isFree = ViewBag.IsFree;
    var referralLink = ViewBag.ReferralLink;
    var showGraduateSection = totalUsers != null;
}

<div class="hero-bg min-h-screen">
  <div class="max-w-6xl mx-auto px-4 py-16">
    
    <div class="text-center mb-12">
      <h1 class="text-5xl font-extrabold mb-4">
        <span class="beat-text">Community</span>
      </h1>
      <p class="text-slate-400 text-lg">Ask questions, share knowledge, connect with @(isGuest ? "professionals" : targetRole + " professionals")</p>
    </div>

    @if (showGraduateSection)
    {
      <!-- Graduate Stats & Referral -->
      <div class="mb-12 space-y-6">
        <!-- Stats -->
        <div class="grid md:grid-cols-3 gap-6">
          <div class="glass-card rounded-2xl p-6 text-center border border-slate-700">
            <div class="text-4xl mb-3">👥</div>
            <div class="text-3xl font-bold text-sky-400 mb-2">@totalUsers</div>
            <div class="text-slate-400 text-sm">Total Users</div>
          </div>
          <div class="glass-card rounded-2xl p-6 text-center border border-slate-700">
            <div class="text-4xl mb-3">🎓</div>
            <div class="text-3xl font-bold text-emerald-400 mb-2">@completedUsers</div>
            <div class="text-slate-400 text-sm">Graduates</div>
          </div>
          <div class="glass-card rounded-2xl p-6 text-center border border-slate-700">
            <div class="text-4xl mb-3">🎁</div>
            <div class="text-3xl font-bold text-purple-400 mb-2">@referralCount</div>
            <div class="text-slate-400 text-sm">Your Referrals</div>
          </div>
        </div>

        <!-- Referral Program -->
        <div class="glass-card rounded-2xl p-8 border-2 @(isFree == true ? "border-emerald-500" : "border-yellow-500")">
          <div class="text-center mb-6">
            <div class="text-5xl mb-4">@(isFree == true ? "🎉" : "🎁")</div>
            <h2 class="text-3xl font-bold text-white mb-3">
              @if (isFree == true)
              {
                <span class="text-emerald-400">Congratulations! ReRhythm is FREE for you!</span>
              }
              else
              {
                <span>Invite Friends, Get Rewards</span>
              }
            </h2>
            <p class="text-slate-300 text-lg mb-2">
              @if (isFree == true)
              {
                <span>You've referred @referralCount premium users. Enjoy 1 year free access!</span>
              }
              else
              {
                <span>Current Discount: <span class="text-yellow-400 font-bold">@discountPercent%</span></span>
              }
            </p>
            <p class="text-slate-400 text-sm">10% off per premium referral • Free for 1 year after 5 premium referrals</p>
          </div>

          <div class="bg-slate-800/50 rounded-xl p-6 mb-6">
            <p class="text-sm font-semibold text-sky-400 mb-3">📋 Your Referral Link:</p>
            <div class="flex gap-2">
              <input type="text" id="referralLink" value="@referralLink" readonly 
                     class="flex-1 bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-slate-300 text-sm" />
              <button onclick="copyReferralLink()" 
                      class="bg-sky-500 hover:bg-sky-600 text-white font-semibold px-6 py-3 rounded-lg transition-colors">
                Copy
              </button>
            </div>
          </div>
        </div>
      </div>
    }

    <!-- Post Question Button -->
    <div class="mb-8">
      @if (isGuest)
      {
        <a href="@Url.Action("Upload", "Resume")" class="glow-btn px-6 py-3 rounded-xl font-semibold flex items-center gap-2 inline-flex">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 4v16m8-8H4"/>
          </svg>
          Sign Up to Ask Questions
        </a>
      }
      else
      {
        <button onclick="showPostModal()" class="glow-btn px-6 py-3 rounded-xl font-semibold flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 4v16m8-8H4"/>
          </svg>
          Ask a Question
        </button>
      }
    </div>

    <!-- Notifications Dropdown -->
    @if (!isGuest)
    {
      <div id="notifDropdown" class="hidden fixed right-4 top-32 w-96 max-h-96 overflow-y-auto glass-card rounded-xl border border-slate-700 z-50 shadow-2xl">
        <div class="p-4 border-b border-slate-700 flex justify-between items-center">
          <h3 class="font-bold text-white">Notifications</h3>
          <button onclick="toggleNotifications()" class="text-slate-400 hover:text-white">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div id="notifList" class="divide-y divide-slate-700">
          <p class="p-4 text-slate-400 text-sm text-center">Loading...</p>
        </div>
      </div>
    }

    <!-- Questions List -->
    <div class="space-y-4 mb-12">
      @foreach (var q in Model.OrderByDescending(x => x.CreatedAt))
      {
        <div class="glass-card rounded-xl p-6 hover:border-sky-500/50 transition-colors cursor-pointer"
             onclick="location.href='@Url.Action("Question", new { id = q.QuestionId, userId })'">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <h3 class="text-xl font-bold text-white mb-2">@q.Title</h3>
              <p class="text-slate-400 text-sm mb-3 line-clamp-2">@q.Content</p>
              <div class="flex items-center gap-4 text-xs text-slate-500">
                <span class="bg-sky-500/20 text-sky-400 px-2 py-1 rounded-md font-semibold">@q.Industry</span>
                <span>@q.UserName</span>
                <span>@q.CreatedAt.ToString("MMM dd, yyyy")</span>
                <span>@q.ViewCount views</span>
                @if (q.ImageUrls.Any())
                {
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    @q.ImageUrls.Count
                  </span>
                }
              </div>
            </div>
            @if (q.AcceptedAnswerId != null)
            {
              <div class="bg-emerald-500/20 text-emerald-400 px-3 py-1 rounded-full text-xs font-semibold">
                ✓ Solved
              </div>
            }
          </div>
        </div>
      }
    </div>

    <!-- Community Features -->
    @if (!isGuest)
    {
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <span class="text-3xl">🤝</span> Community Features
      </h2>
      <div class="grid md:grid-cols-2 gap-6 mb-12">
        
        <!-- Networking (Free) -->
        <div class="glass-card rounded-2xl p-8 border border-slate-700">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-sky-500/20 rounded-xl flex items-center justify-center text-2xl">👥</div>
            <h3 class="text-xl font-bold text-white">Connect with Peers</h3>
          </div>
          <p class="text-slate-300 text-sm mb-6">Find and connect with @targetRole professionals in the community</p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <span class="text-sky-400">✓</span> Browse community members
            </li>
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <span class="text-sky-400">✓</span> Send connection requests
            </li>
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <span class="text-sky-400">✓</span> Build your network
            </li>
          </ul>
          <a href="@Url.Action("Index", "Networking", new { userId })" class="w-full bg-sky-500 hover:bg-sky-600 text-white font-semibold py-3 px-4 rounded-xl transition-colors block text-center">
            Browse Members
          </a>
        </div>

        <!-- Project Showcase (Free) -->
        <div class="glass-card rounded-2xl p-8 border border-slate-700">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-emerald-500/20 rounded-xl flex items-center justify-center text-2xl">🚀</div>
            <h3 class="text-xl font-bold text-white">Project Showcase</h3>
          </div>
          <p class="text-slate-300 text-sm mb-6">Share your portfolio projects and get feedback from peers</p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <span class="text-emerald-400">✓</span> Showcase your work
            </li>
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <span class="text-emerald-400">✓</span> Get peer reviews
            </li>
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <span class="text-emerald-400">✓</span> Build your reputation
            </li>
          </ul>
          <a href="@Url.Action("Index", "Project", new { userId })" class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-semibold py-3 px-4 rounded-xl transition-colors block text-center">
            Share Project
          </a>
        </div>

        <!-- 1-on-1 Mentoring (Premium) -->
        <div class="glass-card rounded-2xl p-8 border @(ViewBag.SubscriptionTier == "Gold" ? "border-slate-700" : "border-yellow-500/50") @(ViewBag.SubscriptionTier != "Gold" ? "opacity-75" : "")">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-purple-500/20 rounded-xl flex items-center justify-center text-2xl">🎯</div>
            <h3 class="text-xl font-bold text-white">1-on-1 Mentoring</h3>
            @if (ViewBag.SubscriptionTier != "Gold")
            {
              <span class="text-xs bg-yellow-500/20 text-yellow-400 px-2 py-1 rounded-full border border-yellow-500/30">⭐ Gold</span>
            }
          </div>
          <p class="text-slate-300 text-sm mb-6">Get personalized guidance from industry experts and senior professionals</p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <span class="text-purple-400">✓</span> Match with senior mentors
            </li>
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <span class="text-purple-400">✓</span> Schedule 1-on-1 sessions
            </li>
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <span class="text-purple-400">✓</span> Career guidance & advice
            </li>
          </ul>
          @if (ViewBag.SubscriptionTier == "Gold")
          {
            <button onclick="showComingSoon('1-on-1 Mentoring')" class="w-full bg-purple-500 hover:bg-purple-600 text-white font-semibold py-3 px-4 rounded-xl transition-colors">
              Find a Mentor
            </button>
          }
          else
          {
            <a href="/Premium/Upgrade" class="w-full bg-yellow-500 hover:bg-yellow-600 text-black font-semibold py-3 px-4 rounded-xl transition-colors block text-center">
              ⭐ Upgrade to Unlock
            </a>
          }
        </div>

        <!-- Live Q&A Sessions (Premium) -->
        <div class="glass-card rounded-2xl p-8 border @(ViewBag.SubscriptionTier == "Gold" ? "border-slate-700" : "border-yellow-500/50") @(ViewBag.SubscriptionTier != "Gold" ? "opacity-75" : "")">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-red-500/20 rounded-xl flex items-center justify-center text-2xl">🎥</div>
            <h3 class="text-xl font-bold text-white">Live Q&A Sessions</h3>
            @if (ViewBag.SubscriptionTier != "Gold")
            {
              <span class="text-xs bg-yellow-500/20 text-yellow-400 px-2 py-1 rounded-full border border-yellow-500/30">⭐ Gold</span>
            }
          </div>
          <p class="text-slate-300 text-sm mb-6">Join weekly live sessions with industry leaders and ask questions in real-time</p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <span class="text-red-400">✓</span> Weekly live sessions
            </li>
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <span class="text-red-400">✓</span> Industry expert speakers
            </li>
            <li class="flex items-center gap-2 text-sm text-slate-300">
              <span class="text-red-400">✓</span> Real-time Q&A
            </li>
          </ul>
          @if (ViewBag.SubscriptionTier == "Gold")
          {
            <button onclick="showComingSoon('Live Q&A Sessions')" class="w-full bg-red-500 hover:bg-red-600 text-white font-semibold py-3 px-4 rounded-xl transition-colors">
              View Schedule
            </button>
          }
          else
          {
            <a href="/Premium/Upgrade" class="w-full bg-yellow-500 hover:bg-yellow-600 text-black font-semibold py-3 px-4 rounded-xl transition-colors block text-center">
              ⭐ Upgrade to Unlock
            </a>
          }
        </div>

      </div>
    }

  </div>
</div>

<!-- Post Question Modal -->
<div id="postModal" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4">
  <div class="glass-card rounded-2xl p-8 max-w-2xl w-full max-h-[90vh] overflow-y-auto">
    <h2 class="text-2xl font-bold text-white mb-6">Ask a Question</h2>
    
    <form id="postForm" enctype="multipart/form-data">
      <input type="hidden" name="userId" value="@userId" />
      
      <div class="mb-4">
        <label class="block text-slate-300 mb-2 font-semibold">Title</label>
        <input type="text" name="title" required maxlength="200" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
               class="w-full bg-slate-800/60 border border-slate-700 rounded-xl px-4 py-3 text-white
                      focus:outline-none focus:border-sky-500" />
      </div>

      <div class="mb-4">
        <label class="block text-slate-300 mb-2 font-semibold">Description</label>
        <textarea name="content" required rows="6" maxlength="2000" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
                  class="w-full bg-slate-800/60 border border-slate-700 rounded-xl px-4 py-3 text-white
                         focus:outline-none focus:border-sky-500"></textarea>
      </div>

      <div class="mb-6">
        <label class="block text-slate-300 mb-2 font-semibold">Images (Max 2, Optional)</label>
        <div id="forumDropZone"
             class="border-2 border-dashed border-slate-600 rounded-xl p-6
                    text-center cursor-pointer transition-all duration-200
                    hover:border-sky-500 hover:bg-sky-500/5"
             onclick="document.getElementById('forumFileInput').click()">
          
          <div id="forumDropDefault">
            <div class="w-10 h-10 mx-auto mb-2 rounded-xl bg-slate-800
                        flex items-center justify-center">
              <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor"
                   stroke-width="2" viewBox="0 0 24 24">
                <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <p class="text-slate-300 font-medium text-sm">Drop images here or click to browse</p>
            <p class="text-slate-500 text-xs mt-1">Max 2 images · JPG, PNG</p>
          </div>

          <div id="forumDropSelected" class="hidden">
            <div class="w-10 h-10 mx-auto mb-2 rounded-xl bg-emerald-500/20
                        flex items-center justify-center">
              <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor"
                   stroke-width="2" viewBox="0 0 24 24">
                <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <p id="forumFileNames" class="text-emerald-400 font-medium text-xs"></p>
            <button type="button" onclick="clearForumFiles(event)"
                    class="text-xs text-slate-500 hover:text-red-400 mt-2
                           transition-colors">✕ Remove</button>
          </div>
        </div>
        <input type="file" id="forumFileInput" name="images" accept="image/*" multiple style="display: none;" />
        <p class="text-xs text-slate-500 mt-1">Images will be checked in background. Inappropriate content will be removed.</p>
      </div>

      <div class="flex gap-3">
        <button type="submit" class="glow-btn px-6 py-3 rounded-xl font-semibold flex-1">
          Post Question
        </button>
        <button type="button" onclick="hidePostModal()"
                class="bg-slate-700 hover:bg-slate-600 px-6 py-3 rounded-xl font-semibold text-white">
          Cancel
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  const isGuest = @Json.Serialize(isGuest);
  const userId = '@userId';
  
  async function loadNotifications() {
    if (isGuest || !userId) return;
    
    const response = await fetch(`@Url.Action("GetNotifications")?userId=${userId}`);
    const notifications = await response.json();
    
    const unreadCount = notifications.filter(n => !n.isRead).length;
    const badge = document.getElementById('navNotifBadge');
    if (badge && unreadCount > 0) {
      badge.textContent = unreadCount > 9 ? '9+' : unreadCount;
      badge.classList.remove('hidden');
    } else if (badge) {
      badge.classList.add('hidden');
    }
    
    const list = document.getElementById('notifList');
    if (notifications.length === 0) {
      list.innerHTML = '<p class="p-4 text-slate-400 text-sm text-center">No notifications</p>';
      return;
    }
    
    list.innerHTML = notifications.map(n => `
      <div class="p-4 hover:bg-slate-800/50 transition-colors ${n.isRead ? 'opacity-60' : ''}" onclick="markRead('${n.notificationId}', '${n.questionId}')">
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 ${
            n.type === 'violation' ? 'bg-red-500/20 text-red-400' :
            n.type === 'answer' ? 'bg-sky-500/20 text-sky-400' :
            'bg-emerald-500/20 text-emerald-400'
          }">
            ${
              n.type === 'violation' ? '⚠️' :
              n.type === 'answer' ? '💬' :
              '✓'
            }
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-slate-300 leading-relaxed">${n.message}</p>
            <p class="text-xs text-slate-500 mt-1">${new Date(n.createdAt).toLocaleString()}</p>
          </div>
        </div>
      </div>
    `).join('');
  }
  
  async function markRead(notificationId, questionId) {
    await fetch('@Url.Action("MarkNotificationRead")', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ notificationId })
    });
    
    if (questionId && questionId !== 'null' && questionId !== '') {
      window.location.href = `@Url.Action("Question")?id=${questionId}&userId=${userId}`;
    } else {
      loadNotifications();
    }
  }
  
  function toggleNotifications() {
    const dropdown = document.getElementById('notifDropdown');
    dropdown.classList.toggle('hidden');
    if (!dropdown.classList.contains('hidden')) {
      loadNotifications();
    }
  }
  
  if (!isGuest) {
    loadNotifications();
    setInterval(loadNotifications, 5000);
  }
  
  function showPostModal() {
    if (isGuest) {
      window.location.href = '@Url.Action("Upload", "Resume")';
      return;
    }
    document.getElementById('postModal').classList.remove('hidden');
  }

  function hidePostModal() {
    document.getElementById('postModal').classList.add('hidden');
  }

  let isSubmitting = false;
  document.getElementById('postForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    if (isSubmitting) return;
    isSubmitting = true;
    
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Posting...';
    
    const formData = new FormData(e.target);
    
    const response = await fetch('@Url.Action("PostQuestion")', {
      method: 'POST',
      body: formData
    });
    
    const result = await response.json();
    if (result.success) {
      location.reload();
    } else {
      alert(result.error);
      isSubmitting = false;
      btn.disabled = false;
      btn.textContent = 'Post Question';
    }
  });

  const forumDropZone = document.getElementById('forumDropZone');
  const forumFileInput = document.getElementById('forumFileInput');
  const forumDropDefault = document.getElementById('forumDropDefault');
  const forumDropSelected = document.getElementById('forumDropSelected');
  const forumFileNames = document.getElementById('forumFileNames');

  function showForumFiles(files) {
    if (files.length > 2) {
      alert('Maximum 2 images allowed');
      forumFileInput.value = '';
      return;
    }
    
    const names = Array.from(files).map(f => f.name).join(', ');
    forumFileNames.textContent = names;
    forumDropDefault.classList.add('hidden');
    forumDropSelected.classList.remove('hidden');
    forumDropZone.classList.add('border-emerald-500', 'bg-emerald-500/5');
    forumDropZone.classList.remove('border-slate-600');
  }

  window.clearForumFiles = function(e) {
    e.stopPropagation();
    forumFileInput.value = '';
    forumDropDefault.classList.remove('hidden');
    forumDropSelected.classList.add('hidden');
    forumDropZone.classList.remove('border-emerald-500', 'bg-emerald-500/5');
    forumDropZone.classList.add('border-slate-600');
  };

  forumFileInput.addEventListener('change', () => {
    if (forumFileInput.files.length > 0) showForumFiles(forumFileInput.files);
  });

  forumDropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    forumDropZone.classList.add('border-sky-500', 'bg-sky-500/5');
  });

  forumDropZone.addEventListener('dragleave', () => {
    forumDropZone.classList.remove('border-sky-500', 'bg-sky-500/5');
  });

  forumDropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    const files = e.dataTransfer.files;
    if (files.length > 0) {
      const dt = new DataTransfer();
      Array.from(files).slice(0, 2).forEach(f => dt.items.add(f));
      forumFileInput.files = dt.files;
      showForumFiles(forumFileInput.files);
    }
    forumDropZone.classList.remove('border-sky-500', 'bg-sky-500/5');
  });

  function copyReferralLink() {
    const input = document.getElementById('referralLink');
    input.select();
    document.execCommand('copy');
    
    const modal = document.createElement('div');
    modal.innerHTML = `
      <div class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 animate-fadeIn" onclick="this.remove()">
        <div class="bg-gradient-to-br from-slate-800 to-slate-900 border-2 border-emerald-500 rounded-2xl p-8 max-w-md mx-4 shadow-2xl animate-slideUp">
          <div class="text-center">
            <div class="text-6xl mb-4">✅</div>
            <h3 class="text-2xl font-bold text-white mb-3">Link Copied!</h3>
            <p class="text-slate-300 mb-4">Share it with friends to earn rewards</p>
            <button onclick="this.closest('.fixed').remove()" class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-semibold py-3 px-6 rounded-xl transition-colors">
              Got it!
            </button>
          </div>
        </div>
      </div>
    `;
    document.body.appendChild(modal);
    setTimeout(() => modal.remove(), 3000);
  }
</script>

<style>
  @@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @@keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  .animate-fadeIn {
    animation: fadeIn 0.3s ease-out;
  }
  .animate-slideUp {
    animation: slideUp 0.4s ease-out;
  }
</style>
