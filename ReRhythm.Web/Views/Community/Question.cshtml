@model ReRhythm.Core.Models.ForumQuestion
@{
    ViewData["Title"] = Model.Title;
    var userId = ViewBag.UserId;
    var answers = (List<ReRhythm.Core.Models.ForumAnswer>)ViewBag.Answers;
}

<div class="hero-bg min-h-screen">
  <div class="max-w-4xl mx-auto px-4 py-16">
    
    <!-- Notifications Dropdown -->
    @if (!string.IsNullOrEmpty(userId))
    {
      <div id="notifDropdown" class="hidden fixed right-4 top-32 w-96 max-h-96 overflow-y-auto glass-card rounded-xl border border-slate-700 z-50 shadow-2xl">
        <div class="p-4 border-b border-slate-700 flex justify-between items-center">
          <h3 class="font-bold text-white">Notifications</h3>
          <button onclick="toggleNotifications()" class="text-slate-400 hover:text-white">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div id="notifList" class="divide-y divide-slate-700">
          <p class="p-4 text-slate-400 text-sm text-center">Loading...</p>
        </div>
      </div>
    }
    
    <!-- Question -->
    <div class="glass-card rounded-2xl p-8 mb-8">
      <h1 class="text-3xl font-bold text-white mb-4">@Model.Title</h1>
      <div class="flex items-center gap-4 text-sm text-slate-400 mb-6">
        <span>@Model.UserName</span>
        <span>@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
      </div>
      <p class="text-slate-300 mb-6 whitespace-pre-wrap">@Model.Content</p>
      
      @if (Model.ImageUrls.Any())
      {
        <div class="flex gap-4 mb-6 flex-wrap">
          @foreach (var img in Model.ImageUrls)
          {
            <img src="@img" alt="Question image" 
                 class="max-w-sm rounded-xl border border-slate-700"
                 onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
                 onload="console.log('Image loaded:', '@img')" />
            <div style="display:none" class="bg-red-500/20 border border-red-500/50 rounded-xl p-4 text-red-400 text-sm">
              <p>⚠️ Image failed to load</p>
              <p class="text-xs text-slate-400 mt-1 break-all">@img</p>
            </div>
          }
        </div>
      }
    </div>

    <!-- Answer Form -->
    <div class="glass-card rounded-xl p-6 mb-8">
      <h2 class="text-xl font-bold text-white mb-4">Your Answer</h2>
      @if (string.IsNullOrEmpty(userId))
      {
        <div class="bg-sky-500/10 border border-sky-500/30 rounded-xl p-6 text-center">
          <p class="text-slate-300 mb-4">Sign in to answer this question and help the community</p>
          <a href="@Url.Action("Upload", "Resume")" class="glow-btn px-6 py-3 rounded-xl font-semibold inline-block">
            Sign Up Free
          </a>
        </div>
      }
      else
      {
        <form id="answerForm">
          <input type="hidden" name="questionId" value="@Model.QuestionId" />
          <input type="hidden" name="userId" value="@userId" />
          <input type="hidden" name="userName" value="@ViewBag.UserName" />
          <textarea name="content" required rows="4" maxlength="2000" placeholder="Share your knowledge..." autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
                    class="w-full bg-slate-800/60 border border-slate-700 rounded-xl px-4 py-3 text-white mb-4
                           focus:outline-none focus:border-sky-500"></textarea>
          <button type="submit" class="glow-btn px-6 py-3 rounded-xl font-semibold">
            Post Answer
          </button>
        </form>
      }
    </div>

    <!-- Answers -->
    <div class="space-y-4">
      <h2 class="text-2xl font-bold text-white mb-4">@answers.Count Answers</h2>
      
      @{
        var sortedAnswers = answers.OrderByDescending(a => a.AnswerId == Model.AcceptedAnswerId)
                                   .ThenByDescending(a => a.Upvotes - a.Downvotes)
                                   .ThenByDescending(a => a.CreatedAt);
      }
      
      @foreach (var answer in sortedAnswers)
      {
        var netVotes = answer.Upvotes - answer.Downvotes;
        var isInappropriate = answer.Downvotes >= 2;
        var isAccepted = answer.AnswerId == Model.AcceptedAnswerId;
        
        <div class="glass-card rounded-xl p-6 @(isInappropriate ? "opacity-50" : "") @(isAccepted ? "border-2 border-emerald-500" : "")"
             data-answer-id="@answer.AnswerId">
          
          @if (isAccepted)
          {
            <div class="bg-emerald-500/20 text-emerald-400 px-3 py-1 rounded-full text-xs font-semibold inline-block mb-4">
              ✓ Accepted Answer
            </div>
          }
          
          @if (isInappropriate)
          {
            <div class="bg-red-500/20 text-red-400 px-3 py-1 rounded-full text-xs font-semibold inline-block mb-4">
              ⚠ Flagged as Inappropriate
            </div>
          }
          
          <div class="flex gap-4">
            <!-- Voting -->
            <div class="flex flex-col items-center gap-2">
              @if (string.IsNullOrEmpty(userId))
              {
                <button onclick="alert('Sign up to vote on answers')" 
                        class="text-slate-400 hover:text-sky-400 transition-colors">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 4l-8 8h5v8h6v-8h5z"/>
                  </svg>
                </button>
                <span class="text-lg font-bold @(netVotes > 0 ? "text-emerald-400" : netVotes < 0 ? "text-red-400" : "text-slate-400")">
                  @netVotes
                </span>
                <button onclick="alert('Sign up to vote on answers')"
                        class="text-slate-400 hover:text-red-400 transition-colors">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 20l8-8h-5V4H9v8H4z"/>
                  </svg>
                </button>
              }
              else
              {
                <button onclick="vote('@answer.AnswerId', true)" 
                        class="text-slate-400 hover:text-sky-400 transition-colors @(answer.UpvotedBy.Contains(userId) ? "text-sky-400" : "")">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 4l-8 8h5v8h6v-8h5z"/>
                  </svg>
                </button>
                <span class="text-lg font-bold @(netVotes > 0 ? "text-emerald-400" : netVotes < 0 ? "text-red-400" : "text-slate-400")">
                  @netVotes
                </span>
                <button onclick="vote('@answer.AnswerId', false)"
                        class="text-slate-400 hover:text-red-400 transition-colors @(answer.DownvotedBy.Contains(userId) ? "text-red-400" : "")">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 20l8-8h-5V4H9v8H4z"/>
                  </svg>
                </button>
              }
            </div>
            
            <!-- Content -->
            <div class="flex-1">
              <p class="text-slate-300 mb-4 whitespace-pre-wrap">@answer.Content</p>
              <div class="flex items-center justify-between">
                <div class="text-sm text-slate-400">
                  <span>@answer.UserName</span>
                  <span class="mx-2">•</span>
                  <span>@answer.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                </div>
                
                @if (Model.UserId == userId && !isAccepted)
                {
                  <button onclick="acceptAnswer('@answer.AnswerId')"
                          class="text-sm text-emerald-400 hover:text-emerald-300 font-semibold">
                    ✓ Accept Answer
                  </button>
                }
              </div>
            </div>
          </div>
        </div>
      }
    </div>

  </div>
</div>

<script>
  const userId = '@userId';
  
  // Notification functions
  async function loadNotifications() {
    if (!userId) return;
    
    const response = await fetch(`/Forum/GetNotifications?userId=${userId}`);
    const notifications = await response.json();
    
    const unreadCount = notifications.filter(n => !n.isRead).length;
    const badge = document.getElementById('navNotifBadge');
    if (badge && unreadCount > 0) {
      badge.textContent = unreadCount > 9 ? '9+' : unreadCount;
      badge.classList.remove('hidden');
    } else if (badge) {
      badge.classList.add('hidden');
    }
    
    const list = document.getElementById('notifList');
    if (notifications.length === 0) {
      list.innerHTML = '<p class="p-4 text-slate-400 text-sm text-center">No notifications</p>';
      return;
    }
    
    list.innerHTML = notifications.map(n => `
      <div class="p-4 hover:bg-slate-800/50 transition-colors ${n.isRead ? 'opacity-60' : ''}" onclick="markRead('${n.notificationId}', '${n.questionId}')">
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 ${
            n.type === 'violation' ? 'bg-red-500/20 text-red-400' :
            n.type === 'answer' ? 'bg-sky-500/20 text-sky-400' :
            'bg-emerald-500/20 text-emerald-400'
          }">
            ${
              n.type === 'violation' ? '⚠️' :
              n.type === 'answer' ? '💬' :
              '✓'
            }
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-slate-300 leading-relaxed">${n.message}</p>
            <p class="text-xs text-slate-500 mt-1">${new Date(n.createdAt).toLocaleString()}</p>
          </div>
        </div>
      </div>
    `).join('');
  }
  
  async function markRead(notificationId, questionId) {
    await fetch('/Forum/MarkNotificationRead', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ notificationId })
    });
    
    if (questionId && questionId !== 'null' && questionId !== '') {
      window.location.href = `/Forum/Question?id=${questionId}&userId=${userId}`;
    } else {
      loadNotifications();
    }
  }
  
  function toggleNotifications() {
    const dropdown = document.getElementById('notifDropdown');
    dropdown.classList.toggle('hidden');
    if (!dropdown.classList.contains('hidden')) {
      loadNotifications();
    }
  }
  
  // Load notifications on page load
  if (userId) {
    loadNotifications();
    setInterval(loadNotifications, 5000);
  }
  
  document.getElementById('answerForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    
    const response = await fetch('@Url.Action("PostAnswer")', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(formData)
    });
    
    const result = await response.json();
    if (result.success) {
      location.reload();
    }
  });

  async function vote(answerId, isUpvote) {
    const response = await fetch('@Url.Action("Vote")', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ answerId, userId: '@userId', isUpvote })
    });
    
    if ((await response.json()).success) {
      location.reload();
    }
  }

  async function acceptAnswer(answerId) {
    const response = await fetch('@Url.Action("AcceptAnswer")', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({ questionId: '@Model.QuestionId', answerId })
    });
    
    if ((await response.json()).success) {
      location.reload();
    }
  }
</script>
