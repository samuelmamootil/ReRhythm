@model ReRhythm.Core.Services.RoadmapPlan
@{
    ViewData["Title"] = "Milestone Tracker";
    var allLessons = ViewBag.AllLessons as List<ReRhythm.Core.Models.LessonPlan> ?? new();
    var isFullyComplete = ViewBag.ProgressPercent >= 100;
    var resumeScore = ViewBag.ResumeScore as ReRhythm.Core.Services.ResumeQualityScore;
}

<div class="hero-bg min-h-screen px-6 py-10">

  <!-- Hero Header -->
  <div class="text-center pt-10 pb-6 px-4">
    <div class="flex justify-center items-center gap-1">
      <img src="~/rhythmlogo.svg" alt="ReRhythm Logo" class="w-20 h-20" />
      <h1 class="text-5xl font-extrabold"><span class="re-text">Re</span><span style="color: #38BDF8;">Rhythm</span></h1>
    </div>
    <h1 class="text-4xl font-extrabold mb-2 leading-tight">
      Milestone <span class="beat-text">Tracker</span>
    </h1>
    <p class="text-slate-400 text-lg max-w-2xl mx-auto">
      Target Role: <span class="text-sky-400 font-semibold">@Model.TargetRole</span>
    </p>
  </div>

  <!-- Step Progress Bar -->
  <partial name="_StepProgress" model="(Model.UserId, 4)" />

  <!-- Header -->
  <div class="max-w-6xl mx-auto mb-12">
    <div class="flex items-center justify-between mb-6">
      <a asp-controller="Roadmap" asp-action="Index" asp-route-userId="@Model.UserId"
         class="text-slate-400 hover:text-white transition-colors">
        ← Back to Roadmap
      </a>
      <a asp-controller="Gamification" asp-action="Dashboard" asp-route-userId="@Model.UserId"
         class="inline-flex items-center gap-2 px-4 py-2 bg-sky-500 hover:bg-sky-600 text-white text-sm font-semibold rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
        </svg>
        View Badges
      </a>
    </div>

    <!-- Overall Progress -->
    <div class="glass-card rounded-2xl p-8 border border-slate-700">
      <div class="grid md:grid-cols-3 gap-6 mb-6">
        <div class="text-center">
          <div class="text-5xl font-bold text-sky-400 mb-2">@ViewBag.ProgressPercent%</div>
          <div class="text-slate-400 text-sm">Overall Progress</div>
        </div>
        <div class="text-center">
          <div class="text-5xl font-bold text-sky-400 mb-2">@ViewBag.CompletedCount</div>
          <div class="text-slate-400 text-sm">Lessons Completed</div>
        </div>
        <div class="text-center">
          <div class="text-5xl font-bold text-slate-400 mb-2">@(ViewBag.TotalLessons - ViewBag.CompletedCount)</div>
          <div class="text-slate-400 text-sm">Lessons Remaining</div>
        </div>
      </div>
      <div class="w-full bg-slate-800/60 border border-slate-700 rounded-full h-4 overflow-hidden">
        <div class="bg-sky-500 h-4 rounded-full transition-all duration-500" 
             style="width: @ViewBag.ProgressPercent%"></div>
      </div>
    </div>
  </div>

  <!-- Resume Quality Score (Free for all users) -->
  @if (resumeScore != null)
  {
    <div class="max-w-6xl mx-auto mb-12">
      <div class="glass-card rounded-2xl p-8 border border-slate-700">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-bold text-white flex items-center gap-3">
            <span class="text-3xl"></span> Your Current Strength
          </h2>
          <div class="text-right">
            <div class="text-5xl font-bold text-sky-400">@resumeScore.Score<span class="text-2xl text-slate-500">/100</span></div>
            <p class="text-xs text-slate-500 mt-1">
              @if (resumeScore.Score >= 80) { <span class="text-emerald-400">Excellent</span> }
              else if (resumeScore.Score >= 60) { <span class="text-sky-400">Good</span> }
              else if (resumeScore.Score >= 40) { <span class="text-yellow-400">Fair</span> }
              else { <span class="text-red-400">Needs Work</span> }
            </p>
          </div>
        </div>
        <div class="grid md:grid-cols-2 gap-4">
          @if (resumeScore.Strengths.Any())
          {
            <div class="bg-emerald-500/10 border border-emerald-500/30 rounded-xl p-4">
              <h3 class="text-sm font-semibold text-emerald-400 mb-2 flex items-center gap-2">
                <span>✅</span> Strengths
              </h3>
              <ul class="space-y-1">
                @foreach (var strength in resumeScore.Strengths.Take(3))
                {
                  <li class="text-slate-300 text-xs flex items-start gap-2">
                    <span class="text-emerald-400 mt-0.5">•</span>
                    <span>@strength</span>
                  </li>
                }
              </ul>
            </div>
          }
          @if (resumeScore.Improvements.Any())
          {
            <div class="bg-sky-500/10 border border-sky-500/30 rounded-xl p-4">
              <h3 class="text-sm font-semibold text-sky-400 mb-2 flex items-center gap-2">
                <span>💡</span> Improve
              </h3>
              <ul class="space-y-1">
                @foreach (var improvement in resumeScore.Improvements.Take(3))
                {
                  <li class="text-slate-300 text-xs flex items-start gap-2">
                    <span class="text-sky-400 mt-0.5">•</span>
                    <span>@improvement</span>
                  </li>
                }
              </ul>
            </div>
          }
        </div>
        @if (ViewBag.SubscriptionTier == "Gold")
        {
          <div class="mt-4 text-center">
            <a asp-controller="Insights" asp-action="Dashboard" asp-route-userId="@Model.UserId" 
               class="inline-flex items-center gap-2 text-sky-400 hover:text-sky-300 text-sm font-semibold transition-colors">
              View Full Insights Dashboard
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        }
        else
        {
          <div class="mt-4 text-center">
            <a href="/Premium/Upgrade" class="inline-flex items-center gap-2 text-yellow-400 hover:text-yellow-300 text-sm font-semibold transition-colors">
              ⭐ Upgrade to Gold for Full Insights Dashboard
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        }
      </div>
    </div>
  }

  <!-- Skills Visualization -->
  <div class="max-w-6xl mx-auto mb-12">
    <h2 class="text-2xl font-bold mb-6 flex items-center gap-3 text-white">
      <span class="text-3xl">🎯</span> Skills Journey
    </h2>
    <div class="grid md:grid-cols-2 gap-6">
      
      <!-- Skills Identified -->
      @if (Model.SkillsIdentified.Any())
      {
        <div class="glass-card rounded-2xl p-6 border border-slate-700">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-sky-500/20 rounded-xl flex items-center justify-center text-xl">✓</div>
            <h3 class="text-xl font-semibold text-white">Current Skills</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            @foreach (var skill in Model.SkillsIdentified)
            {
              <span class="bg-sky-500/10 text-sky-300 text-sm px-4 py-2 rounded-full border border-sky-500/30">@skill</span>
            }
          </div>
        </div>
      }

      <!-- Skills to Acquire -->
      @if (Model.SkillsToAcquire.Any())
      {
        <div class="glass-card rounded-2xl p-6 border border-slate-700">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-sky-500/20 rounded-xl flex items-center justify-center text-xl">⚡</div>
            <h3 class="text-xl font-semibold text-white">Skills to Unlock</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            @foreach (var skill in Model.SkillsToAcquire)
            {
              <span class="bg-sky-500/10 text-sky-300 text-sm px-4 py-2 rounded-full border border-sky-500/30">@skill</span>
            }
          </div>
        </div>
      }
    </div>
  </div>

  <!-- Weekly Milestones -->
  <div class="max-w-6xl mx-auto mb-12">
    <h2 class="text-2xl font-bold mb-6 flex items-center gap-3 text-white">
      <span class="text-3xl">🗓️</span> Weekly Milestones & Portfolio
    </h2>
    <div class="grid md:grid-cols-2 gap-6">
      @foreach (var module in Model.Modules)
      {
        var weekLessons = allLessons.Where(l => l.WeekNumber == module.WeekNumber).ToList();
        var weekCompleted = weekLessons.Count(l => l.IsCompleted);
        var weekTotal = module.DailySprints.Count;
        var weekProgress = weekTotal > 0 ? (int)((weekCompleted / (double)weekTotal) * 100) : 0;
        var isUnlocked = weekProgress == 100;
        
        // Check if week is accessible (Week 1 always accessible, others need previous week complete)
        var isAccessible = module.WeekNumber == 1;
        if (module.WeekNumber > 1)
        {
          var prevWeekLessons = allLessons.Where(l => l.WeekNumber == module.WeekNumber - 1).ToList();
          var prevModule = Model.Modules.FirstOrDefault(m => m.WeekNumber == module.WeekNumber - 1);
          var prevWeekTotal = prevModule?.DailySprints.Count ?? 0;
          var prevWeekCompleted = prevWeekLessons.Count(l => l.IsCompleted);
          isAccessible = prevWeekTotal > 0 && prevWeekCompleted >= prevWeekTotal;
        }

        <div class="glass-card rounded-2xl p-6 border border-slate-700 @(isAccessible ? "hover:border-sky-500 cursor-pointer" : "opacity-50 cursor-not-allowed") transition-colors"
             @Html.Raw(isAccessible ? $"onclick=\"window.location.href='/Roadmap/Module?userId={Model.UserId}&weekNumber={module.WeekNumber}'\"" : "")>
          <div class="flex items-start justify-between mb-4">
            <div>
              <div class="text-xs text-sky-400 font-semibold mb-1">WEEK @module.WeekNumber</div>
              <h3 class="text-xl font-bold text-white mb-2">@module.Theme</h3>
              @if (!isAccessible)
              {
                <p class="text-xs text-slate-500 mt-1 flex items-center gap-1">
                  <span>🔒</span> Complete Week @(module.WeekNumber - 1) to unlock
                </p>
              }
            </div>
            <div class="flex items-center gap-2">
              @if (isUnlocked)
              {
                <div class="text-3xl">🏆</div>
              }
              else if (!isAccessible)
              {
                <div class="text-3xl opacity-30">🔒</div>
              }
              else
              {
                <div class="text-3xl opacity-50">⏳</div>
              }
              @if (isAccessible)
              {
                <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M9 5l7 7-7 7"/>
                </svg>
              }
            </div>
          </div>

          <!-- Week Progress -->
          <div class="mb-4">
            <div class="flex justify-between text-xs text-slate-400 mb-1">
              <span>@weekCompleted / @weekTotal lessons</span>
              <span>@weekProgress%</span>
            </div>
            <div class="w-full bg-slate-800/60 border border-slate-700 rounded-full h-2 overflow-hidden">
              <div class="bg-sky-500 h-2 rounded-full transition-all duration-500" 
                   style="width: @weekProgress%"></div>
            </div>
          </div>

          <!-- Milestones -->
          @if (module.MilestonesUnlocked.Any())
          {
            <div class="mb-3 bg-slate-800/50 rounded-xl p-3 border border-slate-700">
              <p class="text-xs text-slate-400 font-semibold mb-2">MILESTONES</p>
              <ul class="space-y-1">
                @foreach (var m in module.MilestonesUnlocked)
                {
                  <li class="text-sm text-slate-300 flex items-start gap-2">
                    <span class="@(isUnlocked ? "text-sky-400" : "text-slate-600") mt-0.5">@(isUnlocked ? "✓" : "○")</span>
                    <span class="@(isUnlocked ? "" : "opacity-50")">@m</span>
                  </li>
                }
              </ul>
            </div>
          }

          <!-- Portfolio Project -->
          @if (!string.IsNullOrEmpty(module.PortfolioProject))
          {
            <div class="bg-slate-800/50 rounded-xl p-3 border border-slate-700">
              <p class="text-xs text-sky-400 font-semibold mb-1 flex items-center gap-2">
                <span>🛠️</span> PORTFOLIO PROJECT
              </p>
              <p class="text-slate-300 text-sm @(isUnlocked ? "" : "opacity-50")">@module.PortfolioProject</p>
              @if (isUnlocked)
              {
                <span class="inline-block mt-2 text-xs bg-sky-500/20 text-sky-400 px-3 py-1 rounded-full border border-sky-500/30">
                  ✓ Unlocked
                </span>
              }
            </div>
          }
        </div>
      }
    </div>
  </div>

  <!-- Future Resume Preview -->
  <div class="max-w-6xl mx-auto">
    <h2 class="text-2xl font-bold mb-6 flex items-center gap-3 text-white">
      <span class="text-3xl">📄</span> Future-Ready Resume Preview
    </h2>
    <div class="glass-card rounded-2xl p-8 border border-slate-700">
      <div class="mb-6">
        <h3 class="text-xl font-semibold text-white mb-3">Upon Completion, You Will Have:</h3>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Skills Section -->
        <div class="bg-slate-800/50 rounded-xl p-5 border border-slate-700">
          <div class="text-2xl mb-3">💼</div>
          <h4 class="font-semibold text-white mb-2">Technical Skills</h4>
          <p class="text-sm text-slate-400 mb-3">All @Model.SkillsToAcquire.Count target skills mastered</p>
          <div class="flex flex-wrap gap-1">
            @foreach (var skill in Model.SkillsToAcquire.Take(3))
            {
              <span class="text-xs bg-slate-800 text-slate-400 px-2 py-1 rounded border border-slate-700">@skill</span>
            }
            @if (Model.SkillsToAcquire.Count > 3)
            {
              <span class="text-xs text-slate-500">+@(Model.SkillsToAcquire.Count - 3) more</span>
            }
          </div>
        </div>

        <!-- Portfolio Section -->
        <div class="bg-slate-800/50 rounded-xl p-5 border border-slate-700">
          <div class="text-2xl mb-3">🚀</div>
          <h4 class="font-semibold text-white mb-2">Portfolio Projects</h4>
          <p class="text-sm text-slate-400 mb-3">@Model.Modules.Count validated projects</p>
          <ul class="space-y-1">
            @foreach (var module in Model.Modules.Take(2))
            {
              <li class="text-xs text-slate-400">• Week @module.WeekNumber project</li>
            }
            @if (Model.Modules.Count > 2)
            {
              <li class="text-xs text-slate-500">+@(Model.Modules.Count - 2) more</li>
            }
          </ul>
        </div>

        <!-- Certifications Section -->
        <div class="bg-slate-800/50 rounded-xl p-5 border border-slate-700">
          <div class="text-2xl mb-3">🎓</div>
          <h4 class="font-semibold text-white mb-2">Certifications</h4>
          <p class="text-sm text-slate-400 mb-3">Ready for AWS certification</p>
          <div class="text-xs text-sky-400">
            ✓ Hands-on experience<br/>
            ✓ Interview-ready knowledge
          </div>
        </div>
      </div>

      <div class="mt-6 pt-6 border-t border-slate-700">
        <div class="text-center">
          @if (isFullyComplete)
          {
            <p class="text-sky-400 text-sm mb-4 font-semibold">
              Congratulations! You've completed all 28 lessons
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center flex-wrap">
              <a asp-controller="Roadmap" asp-action="DownloadCertificate" asp-route-userId="@Model.UserId"
                 class="glow-btn inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-semibold text-white text-base">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                </svg>
                Download Certificate
              </a>
              <button onclick="shareToLinkedIn()" 
                      class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-semibold text-white text-base bg-sky-500 hover:bg-sky-600 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                Share on LinkedIn
              </button>
              <a asp-controller="Roadmap" asp-action="DownloadEnhancedResume" asp-route-userId="@Model.UserId"
                 onclick="showResumeLoading(event, this.href)"
                 class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-semibold text-white text-base bg-slate-600 hover:bg-slate-500 border border-slate-500 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"/>
                </svg>
                Download Resume
              </a>
            </div>

            <!-- Continue Learning Section -->
            <div class="mt-12 pt-8 border-t border-slate-700">
              <h3 class="text-2xl font-bold text-white mb-6 text-center flex items-center justify-center gap-3">
                <span class="text-3xl">🚀</span> Continue Your Journey
              </h3>
              
              <div class="grid md:grid-cols-2 gap-6 mb-8">
                <!-- Advanced Topics -->
                <div class="bg-gradient-to-br from-sky-500/10 to-purple-500/10 border-2 border-sky-500/30 rounded-xl p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-12 h-12 bg-sky-500/20 rounded-xl flex items-center justify-center text-2xl">📚</div>
                    <h4 class="text-xl font-bold text-white">Advanced Topics</h4>
                  </div>
                  <p class="text-slate-300 text-sm mb-4">Build on your @Model.TargetRole skills with advanced @Model.Industry concepts</p>
                  <div class="space-y-2 mb-4">
                    <div class="flex items-center gap-2 text-sm text-slate-300">
                      <span class="text-sky-400">•</span> AI-generated learning paths
                    </div>
                    <div class="flex items-center gap-2 text-sm text-slate-300">
                      <span class="text-sky-400">•</span> Personalized to your role
                    </div>
                    <div class="flex items-center gap-2 text-sm text-slate-300">
                      <span class="text-sky-400">•</span> Senior-level concepts
                    </div>
                  </div>
                  <a asp-controller="Advanced" asp-action="Index" asp-route-userId="@Model.UserId" class="w-full bg-sky-500 hover:bg-sky-600 text-white font-semibold py-3 px-4 rounded-xl transition-colors block text-center">
                    Explore Advanced Path
                  </a>
                </div>

                <!-- Community -->
                <div class="bg-gradient-to-br from-emerald-500/10 to-sky-500/10 border-2 border-emerald-500/30 rounded-xl p-6">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-12 h-12 bg-emerald-500/20 rounded-xl flex items-center justify-center text-2xl">👥</div>
                    <h4 class="text-xl font-bold text-white">Graduate Community</h4>
                  </div>
                  <p class="text-slate-300 text-sm mb-4">Connect with fellow @Model.TargetRole graduates and industry professionals</p>
                  <div class="space-y-2 mb-4">
                    <div class="flex items-center gap-2 text-sm text-slate-300">
                      <span class="text-emerald-400">•</span> Network with @Model.TargetRole professionals
                    </div>
                    <div class="flex items-center gap-2 text-sm text-slate-300">
                      <span class="text-emerald-400">•</span> Share projects & get feedback
                    </div>
                  </div>
                  <a asp-controller="Community" asp-action="Index" asp-route-userId="@Model.UserId" class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-semibold py-3 px-4 rounded-xl transition-colors block text-center">
                    Join Community
                  </a>
                </div>
              </div>
            </div>
          }
          else
          {
            <p class="text-slate-400 text-sm mb-4">
              Complete all 28 lessons to unlock these features
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center flex-wrap">
              <button disabled
                 class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-semibold text-slate-500 text-base bg-slate-800/50 border-2 border-slate-700 cursor-not-allowed">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                </svg>
                Download Certificate
              </button>
              <button disabled
                 class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-semibold text-slate-500 text-base bg-slate-800/50 border-2 border-slate-700 cursor-not-allowed">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                Share on LinkedIn
              </button>
              <button disabled
                 class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-semibold text-slate-500 text-base bg-slate-800/50 border-2 border-slate-700 cursor-not-allowed">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"/>
                </svg>
                Download Resume
              </button>
            </div>
            <p class="text-xs text-slate-500 mt-3">@(ViewBag.TotalLessons - ViewBag.CompletedCount) lessons remaining</p>
          }
        </div>
      </div>
      
      <style>
        .locked-btn {
          transition: all 0.3s ease;
        }
        .locked-btn:hover {
          border-color: #ef4444;
        }
        @@keyframes shake {
          0%, 100% { transform: translateX(0); }
          10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
          20%, 40%, 60%, 80% { transform: translateX(5px); }
        }
        .shake {
          animation: shake 0.5s;
        }
      </style>
      
      <script>
        function shakeButton() {
          const btn = document.getElementById('lockedResumeBtn');
          btn.classList.add('shake');
          setTimeout(() => btn.classList.remove('shake'), 500);
        }

        function shareToLinkedIn() {
          const userId = '@Model.UserId';
          const targetRole = '@Model.TargetRole';
          const industry = '@Model.Industry';
          const skills = '@string.Join(", ", Model.SkillsToAcquire.Take(5))';
          
          // First, download the certificate
          const certUrl = '/Roadmap/DownloadCertificate?userId=' + userId;
          const link = document.createElement('a');
          link.href = certUrl;
          link.download = `ReRhythm_Certificate_${userId}.pdf`;
          document.body.appendChild(link);
          link.click();
          document.body.removeChild(link);
          
          // Show styled notification modal
          showNotification();
          
          // Then open LinkedIn sharing page
          setTimeout(() => {
            const text = `Excited to share that I've completed the 28-day ReRhythm career development program!\n\nTarget Role: ${targetRole}\nIndustry: ${industry}\nSkills Acquired: ${skills}\n\n28 lessons completed\nPortfolio projects built\nAWS-powered learning\n\nCertificate attached - Verify at: https://rerhythm.com/Roadmap/Verify/${userId}\n\n#CareerDevelopment #AWS #ProfessionalGrowth #ReRhythm #${targetRole.replace(/\s+/g, '')}`;
            
            window.open('https://www.linkedin.com/sharing/share-offsite/', '_blank', 'width=600,height=700');
          }, 500);
        }

        function showNotification() {
          const modal = document.createElement('div');
          modal.innerHTML = `
            <div class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 animate-fadeIn" onclick="this.remove()">
              <div class="bg-gradient-to-br from-slate-800 to-slate-900 border-2 border-sky-500 rounded-2xl p-8 max-w-md mx-4 shadow-2xl animate-slideUp" onclick="event.stopPropagation()">
                <div class="text-center">
                  <div class="w-16 h-16 bg-sky-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <h3 class="text-2xl font-bold text-white mb-3">Certificate Downloaded!</h3>
                  <p class="text-slate-300 mb-6 leading-relaxed">Your certificate has been saved. LinkedIn will open in a moment.</p>
                  <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-4 mb-6 text-left">
                    <p class="text-sm font-semibold text-sky-400 mb-3">📋 Next Steps:</p>
                    <ol class="space-y-2 text-sm text-slate-300">
                      <li class="flex items-start gap-2">
                        <span class="text-sky-400 font-bold">1.</span>
                        <span>Click <strong class="text-white">"Add media"</strong> in LinkedIn post composer</span>
                      </li>
                      <li class="flex items-start gap-2">
                        <span class="text-sky-400 font-bold">2.</span>
                        <span>Upload your <strong class="text-white">certificate PDF</strong></span>
                      </li>
                      <li class="flex items-start gap-2">
                        <span class="text-sky-400 font-bold">3.</span>
                        <span>Click <strong class="text-white">"Post"</strong> to share your achievement!</span>
                      </li>
                    </ol>
                  </div>
                  <button onclick="this.closest('.fixed').remove()" class="w-full bg-sky-500 hover:bg-sky-600 text-white font-semibold py-3 px-6 rounded-xl transition-colors">
                    Got it!
                  </button>
                </div>
              </div>
            </div>
          `;
          document.body.appendChild(modal);
          
          // Auto-close after 10 seconds
          setTimeout(() => modal.remove(), 10000);
        }
        
        function showResumeLoading(event, url) {
          event.preventDefault();
          
          const modal = document.createElement('div');
          modal.innerHTML = `
            <div class="fixed inset-0 bg-black/60 dark:bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 animate-fadeIn">
              <div class="bg-white dark:bg-gradient-to-br dark:from-slate-800 dark:to-slate-900 border-2 border-sky-500 rounded-2xl p-8 max-w-md mx-4 shadow-2xl animate-slideUp">
                <div class="text-center">
                  <div class="w-16 h-16 bg-sky-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="animate-spin w-8 h-8 text-sky-400" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                  </div>
                  <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">Generating Your Resume</h3>
                  <p class="text-gray-700 dark:text-slate-300 mb-4 leading-relaxed">AI is crafting your personalized resume with all your achievements...</p>
                  <p class="text-sm text-gray-600 dark:text-slate-400">This may take 10-15 seconds</p>
                </div>
              </div>
            </div>
          `;
          document.body.appendChild(modal);
          
          // Trigger download
          window.location.href = url;
          
          // Remove modal after 15 seconds
          setTimeout(() => modal.remove(), 15000);
        }

        function showComingSoonModal(feature) {
          const modal = document.createElement('div');
          modal.innerHTML = `
            <div class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 animate-fadeIn" onclick="this.remove()">
              <div class="bg-gradient-to-br from-slate-800 to-slate-900 border-2 border-sky-500 rounded-2xl p-8 max-w-md mx-4 shadow-2xl animate-slideUp" onclick="event.stopPropagation()">
                <div class="text-center">
                  <div class="text-6xl mb-4">🚀</div>
                  <h3 class="text-2xl font-bold text-white mb-3">${feature}</h3>
                  <p class="text-slate-300 mb-6 leading-relaxed">This feature is coming soon! We're building an amazing experience for our graduates.</p>
                  <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-4 mb-6">
                    <p class="text-sm text-sky-400 mb-2">✨ Get notified when it launches</p>
                    <p class="text-xs text-slate-400">We'll email you as soon as ${feature} is ready</p>
                  </div>
                  <button onclick="this.closest('.fixed').remove()" class="w-full bg-sky-500 hover:bg-sky-600 text-white font-semibold py-3 px-6 rounded-xl transition-colors">
                    Got it!
                  </button>
                </div>
              </div>
            </div>
          `;
          document.body.appendChild(modal);
        }

        // Load topics when page loads if user completed
        if (@(isFullyComplete ? "true" : "false")) {
          // Topics are loaded on the Advanced page
        }
      </script>
      
      <style>
        @@keyframes fadeIn {
          from { opacity: 0; }
          to { opacity: 1; }
        }
        @@keyframes slideUp {
          from { transform: translateY(20px); opacity: 0; }
          to { transform: translateY(0); opacity: 1; }
        }
        .animate-fadeIn {
          animation: fadeIn 0.3s ease-out;
        }
        .animate-slideUp {
          animation: slideUp 0.4s ease-out;
        }
      </style>
    </div>
  </div>

</div>
