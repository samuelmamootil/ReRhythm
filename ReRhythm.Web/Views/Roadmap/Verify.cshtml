@model ReRhythm.Core.Services.RoadmapPlan?

@{
    ViewData["Title"] = "Certificate Verification";
    var isVerified = ViewBag.IsVerified ?? false;
    var completedCount = ViewBag.CompletedCount ?? 0;
    var totalLessons = ViewBag.TotalLessons ?? 0;
    var completionDate = ViewBag.CompletionDate as DateTime?;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ReRhythm</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900 min-h-screen">
    <div class="container mx-auto px-4 py-16">
        <div class="max-w-2xl mx-auto">
            <!-- Header -->
            <div class="text-center mb-8">
                <h1 class="text-5xl font-bold text-sky-400 mb-2">ReRhythm</h1>
                <p class="text-slate-300">AWS-Powered Career Coaching Platform</p>
            </div>

            <!-- Verification Card -->
            <div class="bg-white rounded-2xl shadow-2xl p-8">
                @if (Model == null)
                {
                    <!-- Invalid Certificate -->
                    <div class="text-center py-8">
                        <div class="w-20 h-20 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-10 h-10 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </div>
                        <h2 class="text-2xl font-bold text-slate-900 mb-2">Certificate Not Found</h2>
                        <p class="text-slate-600">This certificate ID is invalid or does not exist.</p>
                    </div>
                }
                else if (isVerified)
                {
                    <!-- Verified Certificate -->
                    <div class="text-center py-8">
                        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <h2 class="text-2xl font-bold text-green-600 mb-6">✓ Certificate Verified</h2>
                        
                        <div class="bg-slate-50 rounded-lg p-6 text-left space-y-3">
                            <div class="flex justify-between border-b border-slate-200 pb-2">
                                <span class="font-semibold text-slate-700">User ID:</span>
                                <span class="text-slate-900">@Model.UserId</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-200 pb-2">
                                <span class="font-semibold text-slate-700">Target Role:</span>
                                <span class="text-slate-900">@Model.TargetRole</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-200 pb-2">
                                <span class="font-semibold text-slate-700">Industry:</span>
                                <span class="text-slate-900">@Model.Industry</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-200 pb-2">
                                <span class="font-semibold text-slate-700">Completion Date:</span>
                                <span class="text-slate-900">@completionDate?.ToString("MMMM dd, yyyy")</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="font-semibold text-slate-700">Lessons Completed:</span>
                                <span class="text-green-600 font-bold">@completedCount / @totalLessons (100%)</span>
                            </div>
                        </div>

                        <p class="text-sm text-slate-500 mt-6">
                            This certificate confirms successful completion of the 28-day ReRhythm career development program.
                        </p>
                    </div>
                }
                else
                {
                    <!-- Incomplete Certificate -->
                    <div class="text-center py-8">
                        <div class="w-20 h-20 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-10 h-10 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <h2 class="text-2xl font-bold text-yellow-600 mb-2">Certificate Incomplete</h2>
                        <p class="text-slate-600 mb-6">This user has not completed all required lessons.</p>
                        
                        <div class="bg-slate-50 rounded-lg p-6 text-left space-y-3">
                            <div class="flex justify-between border-b border-slate-200 pb-2">
                                <span class="font-semibold text-slate-700">User ID:</span>
                                <span class="text-slate-900">@Model.UserId</span>
                            </div>
                            <div class="flex justify-between border-b border-slate-200 pb-2">
                                <span class="font-semibold text-slate-700">Target Role:</span>
                                <span class="text-slate-900">@Model.TargetRole</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="font-semibold text-slate-700">Progress:</span>
                                <span class="text-yellow-600 font-bold">@completedCount / @totalLessons (@((int)((completedCount / (double)totalLessons) * 100))%)</span>
                            </div>
                        </div>
                    </div>
                }

                <!-- Back Button -->
                <div class="text-center mt-8">
                    <a href="/" class="text-sky-600 hover:text-sky-700 font-medium">← Back to Home</a>
                </div>
            </div>

            <!-- Footer -->
            <div class="text-center mt-8 text-slate-400 text-sm">
                <p>ReRhythm - AWS Hackathon Top 3 Finalist</p>
            </div>
        </div>
    </div>
</body>
</html>
