@model ReRhythm.Core.Services.RoadmapPlan
@{
    ViewData["Title"] = "Your 28-Day Roadmap";
}

<div class="hero-bg min-h-screen px-6 py-10">

  <!-- Hero Header -->
  <div class="text-center pt-10 pb-6 px-4">
    <div class="flex justify-center">
      <img src="~/rhythmlogo.png" alt="ReRhythm Logo" class="h-32 page-logo m-0 p-0" />
    </div>
    <h1 class="text-4xl font-extrabold mb-2 leading-tight">
      Your 28-Day <span class="beat-text">Roadmap</span>
    </h1>
    <p class="text-slate-400 text-lg max-w-2xl mx-auto">
      Target Role: <span class="text-sky-400 font-semibold">@Model.TargetRole</span>
    </p>
  </div>

  <!-- Step Progress Bar -->
  <partial name="_StepProgress" model="(Model.UserId, 3)" />

  <!-- Header with Progress -->
  <div class="max-w-5xl mx-auto mb-8">
    <div class="flex items-center justify-between mb-4">
      <a asp-controller="Roadmap" asp-action="Index" asp-route-userId="@Model.UserId"
         class="text-slate-400 hover:text-white transition-colors text-sm">
        ← Back to Roadmap
      </a>
      <div class="text-right">
        <div class="text-3xl font-bold text-sky-400">@ViewBag.ProgressPercent%</div>
        <div class="text-sm text-slate-400">Complete</div>
      </div>
    </div>
    <div class="w-full bg-slate-800/60 border border-slate-700 rounded-full h-3 overflow-hidden">
      <div class="bg-sky-500 h-3 rounded-full transition-all duration-500" style="width: @ViewBag.ProgressPercent%"></div>
    </div>
    <p class="text-slate-400 text-sm mt-2">@ViewBag.CompletedCount of @ViewBag.TotalLessons lessons complete · Generated: @Model.GeneratedAt.ToString("MMM dd, yyyy")</p>
  </div>

  <!-- Quick Actions -->
  <div class="max-w-5xl mx-auto mb-8">
    <div class="grid md:grid-cols-3 gap-4">
      <a asp-controller="Roadmap" asp-action="Module" asp-route-userId="@Model.UserId" asp-route-weekNumber="1"
         class="glass-card rounded-xl p-4 border border-slate-700 hover:border-sky-500 transition-colors flex items-center gap-4">
        <div class="w-12 h-12 bg-sky-500/20 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="font-semibold text-white mb-1">Start Learning</h3>
          <p class="text-xs text-slate-400">Begin your 28-day journey</p>
        </div>
        <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      <a asp-controller="Roadmap" asp-action="Tracker" asp-route-userId="@Model.UserId"
         class="glass-card rounded-xl p-4 border border-slate-700 hover:border-sky-500 transition-colors flex items-center gap-4">
        <div class="w-12 h-12 bg-sky-500/20 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="font-semibold text-white mb-1">Track Milestones</h3>
          <p class="text-xs text-slate-400">View your progress & achievements</p>
        </div>
        <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      <a asp-controller="Roadmap" asp-action="DownloadResume" asp-route-userId="@Model.UserId"
         class="glass-card rounded-xl p-4 border border-slate-700 hover:border-sky-500 transition-colors flex items-center gap-4">
        <div class="w-12 h-12 bg-sky-500/20 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="font-semibold text-white mb-1">Get Resume PDF</h3>
          <p class="text-xs text-slate-400">Professional ATS-friendly format</p>
        </div>
        <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Skills Gap & Tips -->
  <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-6 mb-12">
    
    <!-- Skills Gap -->
    @if (Model.SkillsToAcquire.Any())
    {
      <div class="glass-card rounded-2xl p-6 border border-slate-700">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-sky-500/20 rounded-xl flex items-center justify-center text-xl">🎯</div>
          <h2 class="text-xl font-semibold text-white">Skills to Acquire</h2>
        </div>
        <div class="flex flex-wrap gap-2">
          @foreach (var skill in Model.SkillsToAcquire)
          {
            <span class="bg-slate-800/60 text-slate-300 text-sm px-4 py-2 rounded-full border border-slate-700">@skill</span>
          }
        </div>
      </div>
    }

    <!-- Quick Tips -->
    <div class="glass-card rounded-2xl p-6 border border-slate-700">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 bg-sky-500/20 rounded-xl flex items-center justify-center text-xl">💡</div>
        <h2 class="text-xl font-semibold text-white">Pro Tips</h2>
      </div>
      <ul class="space-y-2 text-sm text-slate-300">
        <li class="flex items-start gap-2">
          <span class="text-sky-400 mt-1">✓</span>
          <span>Complete daily sprints consistently for best results</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-sky-400 mt-1">✓</span>
          <span>Build portfolio projects to showcase your skills</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-sky-400 mt-1">✓</span>
          <span>Track your progress and celebrate small wins</span>
        </li>
      </ul>
    </div>
  </div>

  <!-- Raw Content (if structured data not available) -->
  @if (!string.IsNullOrEmpty(Model.RawContent) && !Model.Modules.Any())
  {
    <div class="max-w-5xl mx-auto mb-12">
      <h2 class="text-2xl font-bold mb-6 flex items-center gap-3 text-white">
        <span class="text-3xl">📋</span> Your Learning Roadmap
      </h2>
      <div class="glass-card rounded-2xl p-8 border border-slate-700">
        <div class="bg-slate-800/60 rounded-xl p-6 border border-slate-700">
          <p class="text-slate-400 text-sm mb-4">⚠️ Roadmap data is still being processed. Please refresh in a moment.</p>
          <details class="cursor-pointer">
            <summary class="text-sky-400 text-sm font-semibold cursor-pointer hover:text-sky-300">View Raw Response</summary>
            <pre class="mt-4 whitespace-pre-wrap text-xs text-slate-400 leading-relaxed overflow-x-auto">@Model.RawContent</pre>
          </details>
        </div>
      </div>
    </div>
  }

  <!-- Timeline View -->
  @if (Model.Modules.Any())
  {
    var allLessons = ViewBag.AllLessons as List<ReRhythm.Core.Models.LessonPlan> ?? new();
    
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold mb-8 flex items-center gap-3 text-white">
        <span class="text-3xl">📅</span> 4-Week Timeline
      </h2>
      
      <div class="relative">
        
        <div class="space-y-8">
          @foreach (var module in Model.Modules)
          {
            var weekLessons = allLessons.Where(l => l.WeekNumber == module.WeekNumber).ToList();
            var weekCompleted = weekLessons.Count(l => l.IsCompleted);
            var weekTotal = module.DailySprints.Count;
            var isWeekComplete = weekCompleted == weekTotal && weekTotal > 0;
            
            // Check if previous week is complete (Week 1 is always unlocked)
            var isPreviousWeekComplete = module.WeekNumber == 1;
            if (module.WeekNumber > 1)
            {
              var prevWeekLessons = allLessons.Where(l => l.WeekNumber == module.WeekNumber - 1).ToList();
              var prevModule = Model.Modules.FirstOrDefault(m => m.WeekNumber == module.WeekNumber - 1);
              var prevWeekTotal = prevModule?.DailySprints.Count ?? 0;
              var prevWeekCompleted = prevWeekLessons.Count(l => l.IsCompleted);
              isPreviousWeekComplete = prevWeekTotal > 0 && prevWeekCompleted >= prevWeekTotal;
            }
            
            var isLocked = !isPreviousWeekComplete;
            
            <div class="relative pl-20 week-module @(isLocked ? "locked" : "unlocked")" data-week="@module.WeekNumber">
              <!-- Timeline Dot -->
              <div class="absolute left-4 w-9 h-9 @(isLocked ? "bg-slate-800 border-slate-600" : "bg-sky-500/20 border-sky-500") border-2 rounded-full flex items-center justify-center font-bold @(isLocked ? "text-slate-600" : "text-sky-400") transition-all duration-500">
                @if (isLocked)
                {
                  <span class="text-lg">🔒</span>
                }
                else
                {
                  @module.WeekNumber
                }
              </div>
              
              <!-- Module Card -->
              <div class="glass-card rounded-2xl p-6 border @(isLocked ? "border-slate-800 opacity-50" : "border-slate-700 hover:border-sky-500") transition-all duration-500">
                <div class="flex items-start justify-between mb-4">
                  <div>
                    <div class="text-xs @(isLocked ? "text-slate-600" : "text-sky-400") font-semibold mb-1">WEEK @module.WeekNumber</div>
                    <h3 class="text-2xl font-bold @(isLocked ? "text-slate-600" : "text-white") mb-2">@module.Theme</h3>
                    @if (isLocked)
                    {
                      <p class="text-xs text-slate-500 mt-2 flex items-center gap-2">
                        <span>🔒</span> Complete Week @(module.WeekNumber - 1) to unlock
                      </p>
                    }
                  </div>
                  @if (isLocked)
                  {
                    <button disabled class="px-5 py-2 rounded-xl text-sm font-semibold bg-slate-800 text-slate-600 cursor-not-allowed">
                      Locked
                    </button>
                  }
                  else
                  {
                    var hasStarted = weekCompleted > 0;
                    <a asp-controller="Roadmap" asp-action="Module"
                       asp-route-userId="@Model.UserId"
                       asp-route-weekNumber="@module.WeekNumber"
                       class="glow-btn px-5 py-2 rounded-xl text-sm font-semibold text-white">
                      @(hasStarted ? "Continue Learning →" : "Start Week →")
                    </a>
                  }
                </div>

                <!-- Milestones -->
                @if (module.MilestonesUnlocked.Any())
                {
                  <div class="mb-4 bg-slate-800/50 rounded-xl p-4 border border-slate-700">
                    <p class="text-sm @(isLocked ? "text-slate-600" : "text-sky-400") font-semibold mb-2 flex items-center gap-2">
                      <span class="text-lg">🏆</span> Milestones You'll Unlock
                    </p>
                    <ul class="space-y-1">
                      @foreach (var m in module.MilestonesUnlocked)
                      {
                        <li class="text-sm @(isLocked ? "text-slate-600" : "text-slate-300") flex items-start gap-2">
                          <span class="@(isLocked ? "text-slate-600" : "text-sky-400") mt-0.5">✓</span>
                          <span>@m</span>
                        </li>
                      }
                    </ul>
                  </div>
                }

                <!-- Portfolio Project -->
                @if (!string.IsNullOrEmpty(module.PortfolioProject))
                {
                  <div class="mb-4 bg-slate-800/50 rounded-xl p-4 border border-slate-700">
                    <p class="text-sm @(isLocked ? "text-slate-600" : "text-sky-400") font-semibold flex items-center gap-2">
                      <span class="text-lg">🛠️</span> Portfolio Project
                    </p>
                    <p class="@(isLocked ? "text-slate-600" : "text-slate-300") text-sm mt-1">@module.PortfolioProject</p>
                  </div>
                }

                <!-- Daily Sprints Preview -->
                @if (module.DailySprints.Any() && !isLocked)
                {
                  <div class="space-y-2">
                    <p class="text-xs text-slate-400 font-semibold mb-3">DAILY SPRINTS PREVIEW</p>
                    @{
                      var startDate = Model.GeneratedAt.AddDays((module.WeekNumber - 1) * 7);
                    }
                    @foreach (var sprint in module.DailySprints.Take(3))
                    {
                      var sprintDate = startDate.AddDays(sprint.Day - 1);
                      <div class="bg-slate-800/50 rounded-lg p-3 hover:bg-slate-800 transition-colors border border-slate-700">
                        <div class="flex items-start gap-3">
                          <div class="flex-shrink-0">
                            <div class="w-10 h-10 bg-sky-500/20 rounded-lg flex items-center justify-center text-sky-400 font-bold text-xs">
                              @sprint.Day
                            </div>
                            <div class="text-xs text-slate-500 text-center mt-1">@sprintDate.ToString("MMM dd")</div>
                          </div>
                          <div class="flex-1 min-w-0">
                            <p class="text-sm text-slate-300 break-words leading-relaxed">@sprint.Topic</p>
                            <span class="inline-block mt-2 text-xs bg-slate-800 text-slate-400 px-3 py-1 rounded-full border border-slate-700 whitespace-nowrap">@sprint.EstimatedMinutes min</span>
                          </div>
                        </div>
                      </div>
                    }
                    @if (module.DailySprints.Count > 3)
                    {
                      <p class="text-xs text-slate-500 text-center pt-2">
                        + @(module.DailySprints.Count - 3) more daily sprints
                      </p>
                    }
                  </div>
                }
              </div>
            </div>
          }
        </div>
      </div>
    </div>
  }



</div>

<style>
@@keyframes unlock-pulse {
  0%, 100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.1); opacity: 1; }
}

@@keyframes unlock-fade-in {
  from { opacity: 0.5; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.week-module.locked {
  pointer-events: none;
}

.week-module.unlocked.just-unlocked {
  animation: unlock-fade-in 0.8s ease-out;
}

.week-module.unlocked.just-unlocked .absolute {
  animation: unlock-pulse 1s ease-in-out;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const urlParams = new URLSearchParams(window.location.search);
  const justCompleted = urlParams.get('weekCompleted');
  
  if (justCompleted) {
    const nextWeek = parseInt(justCompleted) + 1;
    const nextWeekModule = document.querySelector(`.week-module[data-week="${nextWeek}"]`);
    
    if (nextWeekModule && nextWeekModule.classList.contains('unlocked')) {
      setTimeout(() => {
        nextWeekModule.classList.add('just-unlocked');
        
        const notification = document.createElement('div');
        notification.className = 'fixed top-20 left-1/2 transform -translate-x-1/2 bg-sky-500 text-white px-6 py-4 rounded-xl shadow-2xl z-50 animate-bounce';
        notification.innerHTML = `
          <div class="flex items-center gap-3">
            <span class="text-2xl">🎉</span>
            <div>
              <div class="font-bold">Week ${nextWeek} Unlocked!</div>
              <div class="text-sm opacity-90">Great job completing Week ${justCompleted}!</div>
            </div>
          </div>
        `;
        document.body.appendChild(notification);
        
        setTimeout(() => {
          nextWeekModule.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 500);
        
        setTimeout(() => {
          notification.style.opacity = '0';
          notification.style.transition = 'opacity 0.5s';
          setTimeout(() => notification.remove(), 500);
        }, 4000);
        
        window.history.replaceState({}, '', window.location.pathname + '?userId=' + urlParams.get('userId'));
      }, 300);
    }
  }
});
</script>
  animation: unlock-fade-in 0.8s ease-out;
}

