@{
    ViewData["Title"] = "Upload Resume";
}

<div class="hero-bg min-h-screen">

  <!-- Hero Header -->
  <div class="text-center pt-16 pb-10 px-4">
    <div class="flex justify-center">
      <img src="~/rhythmlogo.png" alt="ReRhythm Logo" class="h-32 page-logo m-0 p-0" />
    </div>
    <h1 class="text-5xl font-extrabold mb-4 leading-tight">
      Catch the Industry <span class="beat-text">Beat</span>
    </h1>
    <p class="text-slate-400 text-lg max-w-2xl mx-auto">
      Upload your resume → get a personalized 28-day roadmap → learn with AI-powered
      micro-lessons anchored in AWS documentation.
    </p>
  </div>

  <!-- Step Progress Bar -->
  <div class="flex items-center justify-center gap-0 mb-10 px-4">
    @{
      var steps = new[] {
        ("Upload Resume", true),
        ("Skill Analysis", false),
        ("28-Day Roadmap", false),
        ("Lessons & Milestones", false)
      };
    }
    @for (int i = 0; i < steps.Length; i++)
    {
      bool active = steps[i].Item2;
      <div class="flex items-center">
        <!-- Circle -->
        <div class="flex flex-col items-center">
          <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold
                      border-2 @(active ? "border-sky-400 bg-sky-400/20 text-sky-400"
                                        : "border-slate-600 text-slate-500")">
            @(i + 1)
          </div>
          <span class="text-xs mt-1 @(active ? "text-sky-400" : "text-slate-500")
                       whitespace-nowrap">
            @steps[i].Item1
          </span>
        </div>
        <!-- Connector line (not after last) -->
        @if (i < steps.Length - 1)
        {
          <div class="w-20 h-px mx-2 mb-4 bg-slate-700"></div>
        }
      </div>
    }
  </div>

  <!-- Upload Card -->
  <div class="max-w-2xl mx-auto px-4 pb-20">
    <div class="glass-card rounded-2xl p-8">

      <!-- Card Header -->
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-xl bg-sky-500/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor"
               stroke-width="2" viewBox="0 0 24 24">
            <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586
                     a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <div>
          <h2 class="text-xl font-bold text-white">Upload Your Resume</h2>
          <p class="text-slate-400 text-sm">PDF format · Max 10MB · Analyzed by AWS Textract + Bedrock</p>
        </div>
      </div>

      <form asp-controller="Resume" asp-action="Upload"
            method="post" enctype="multipart/form-data" id="uploadForm">

        <!-- User ID Field -->
        <div class="mb-5">
          <label class="block text-sm font-medium text-slate-300 mb-2">Your User ID</label>
          <div class="relative">
            <svg class="absolute left-3 top-3 w-4 h-4 text-slate-500"
                 fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <input type="text" name="userId" id="userId" placeholder="e.g. john-doe-123" required
                   pattern="[a-zA-Z0-9_-]+" title="Only letters, numbers, hyphens, and underscores allowed"
                   class="w-full bg-slate-800/60 border border-slate-700 rounded-xl
                          pl-10 pr-4 py-3 text-white placeholder-slate-500
                          focus:outline-none focus:border-sky-500 focus:ring-1
                          focus:ring-sky-500 transition-colors" />
          </div>
          <p id="userIdError" class="text-xs text-red-400 mt-1 hidden">Can't use characters other than letters, numbers, hyphens (-), and underscores (_)</p>
          <p id="userIdExists" class="text-xs text-amber-400 mt-1 hidden">This User ID already exists. <a href="#" id="goToTracker" class="underline hover:text-amber-300">Click here to track your progress</a></p>
          <p id="userIdAvailable" class="text-xs text-emerald-400 mt-1 hidden">✓ User ID is available</p>
          <p class="text-xs text-slate-500 mt-1">Letters, numbers, hyphens, and underscores only (e.g., john_doe-123)</p>
        </div>

        <!-- Years of Experience Field -->
        <div class="mb-5">
          <label class="block text-sm font-medium text-slate-300 mb-2">Years of Experience</label>
          <input type="number" name="yearsOfExperience" min="0" max="50" required
                 class="w-full bg-slate-800/60 border border-slate-700 rounded-xl
                        px-4 py-3 text-white placeholder-slate-500
                        focus:outline-none focus:border-sky-500 focus:ring-1
                        focus:ring-sky-500 transition-colors" />
        </div>

        <!-- Industry Field -->
        <div class="mb-5">
          <label class="block text-sm font-medium text-slate-300 mb-2">Target Industry</label>
          <select name="industry" id="industry" required
                  class="w-full bg-slate-800/60 border border-slate-700 rounded-xl
                         px-4 py-3 text-white
                         focus:outline-none focus:border-sky-500 focus:ring-1
                         focus:ring-sky-500 transition-colors">
            <option value="">Select Industry</option>
            <option value="IT">Information Technology & Software</option>
            <option value="Healthcare">Healthcare & Life Sciences</option>
            <option value="Finance">Finance & Banking</option>
            <option value="Manufacturing">Manufacturing & Industrial</option>
            <option value="Automotive">Automotive</option>
            <option value="Aerospace">Aerospace & Defense</option>
            <option value="Energy">Energy & Utilities</option>
            <option value="Telecommunications">Telecommunications</option>
            <option value="Retail">Retail & E-commerce</option>
            <option value="Education">Education & EdTech</option>
            <option value="Consulting">Consulting & Professional Services</option>
            <option value="Media">Media & Entertainment</option>
            <option value="RealEstate">Real Estate & Construction</option>
            <option value="Logistics">Logistics & Supply Chain</option>
            <option value="Hospitality">Hospitality & Tourism</option>
            <option value="Government">Government & Public Sector</option>
          </select>
        </div>

        <!-- Target Role Field -->
        <div class="mb-5">
          <label class="block text-sm font-medium text-slate-300 mb-2">Target Role</label>
          <select name="targetRole" id="targetRole" required
                  class="w-full bg-slate-800/60 border border-slate-700 rounded-xl
                         px-4 py-3 text-white
                         focus:outline-none focus:border-sky-500 focus:ring-1
                         focus:ring-sky-500 transition-colors">
            <option value="">Select role first</option>
          </select>
        </div>

        <!-- Hidden field for personality type -->
        <input type="hidden" name="personalityType" id="personalityTypeInput" value="" />

        <!-- Personality Test Button (before file upload) -->
        <div class="mb-6">
          <div class="bg-slate-800/60 border border-slate-700 rounded-xl p-4 hover:border-sky-500/50 transition-colors">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-sky-500/20 flex items-center justify-center">
                  <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-white font-semibold text-sm">Personalize Your Roadmap</p>
                  <p class="text-slate-400 text-xs">2-min quiz • Get AI-tailored learning path</p>
                </div>
              </div>
              <button type="button" id="startPersonalityTest" disabled
                      class="px-4 py-2 bg-slate-600 text-white text-sm font-semibold rounded-lg cursor-not-allowed transition-colors">
                Start Quiz
              </button>
            </div>
            <div id="personalityResult" class="hidden mt-3 pt-3 border-t border-slate-700">
              <p class="text-sm text-sky-300">✓ <span id="personalityType"></span></p>
            </div>
          </div>
        </div>

        <!-- Drag & Drop File Zone -->
        <div class="mb-6">
          <label class="block text-sm font-medium text-slate-300 mb-2">Resume File</label>
          <div id="dropZone"
               class="border-2 border-dashed border-slate-600 rounded-xl p-8
                      text-center cursor-pointer transition-all duration-200
                      hover:border-sky-500 hover:bg-sky-500/5"
               onclick="document.getElementById('fileInput').click()">

            <!-- Default state -->
            <div id="dropDefault">
              <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-slate-800
                          flex items-center justify-center">
                <svg class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor"
                     stroke-width="2" viewBox="0 0 24 24">
                  <path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0
                           011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                </svg>
              </div>
              <p class="text-slate-300 font-medium">Drop your resume here</p>
              <p class="text-slate-500 text-sm mt-1">or click to browse · PDF or DOCX only</p>
            </div>

            <!-- File selected state (hidden by default) -->
            <div id="dropSelected" class="hidden">
              <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-emerald-500/20
                          flex items-center justify-center">
                <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor"
                     stroke-width="2" viewBox="0 0 24 24">
                  <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586
                           a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
              <p id="fileName" class="text-emerald-400 font-medium text-sm"></p>
              <p id="fileSize" class="text-slate-500 text-xs mt-1"></p>
              <button type="button" onclick="clearFile(event)"
                      class="text-xs text-slate-500 hover:text-red-400 mt-2
                             transition-colors">✕ Remove</button>
            </div>

          </div>
          <input type="file" id="fileInput" name="resume" accept=".pdf,.docx" required style="display: none;" />
        </div>

        <!-- Error Message -->
        <div id="errorMsg" class="hidden mb-4 px-4 py-3 bg-red-900/40 border
             border-red-700 rounded-xl text-red-300 text-sm">
          Upload failed. Check that AWS resources are configured.
        </div>

        <!-- Submit Button -->
        <button type="submit" id="submitBtn"
                class="glow-btn w-full text-white font-semibold py-4 rounded-xl
                       flex items-center justify-center gap-2 text-base">
          <svg class="w-5 h-5" fill="none" stroke="currentColor"
               stroke-width="2" viewBox="0 0 24 24">
            <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3
                     m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374
                     3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
          Analyze Resume
        </button>

      </form>
    </div>
  </div>
</div>

@section Scripts {
<script>
  const dropZone   = document.getElementById('dropZone');
  const fileInput  = document.getElementById('fileInput');
  const dropDef    = document.getElementById('dropDefault');
  const dropSel    = document.getElementById('dropSelected');
  const fileName   = document.getElementById('fileName');
  const fileSize   = document.getElementById('fileSize');
  const userIdInput = document.getElementById('userId');
  const userIdError = document.getElementById('userIdError');
  const userIdExists = document.getElementById('userIdExists');
  const userIdAvailable = document.getElementById('userIdAvailable');
  let checkTimeout;
  let isUserIdValid = false;
  let personalityScores = { R: 0, I: 0, A: 0, S: 0, E: 0, C: 0 };

  // Personality Test Data (12 visual questions)
  const personalityQuestions = [
    { img: '🔧', text: 'Fix & Build Things', type: 'R', alt: 'Working with tools and machines' },
    { img: '🔬', text: 'Analyze & Research', type: 'I', alt: 'Solving complex problems' },
    { img: '🎨', text: 'Create & Design', type: 'A', alt: 'Artistic and creative work' },
    { img: '🤝', text: 'Help & Teach Others', type: 'S', alt: 'Working with people' },
    { img: '💼', text: 'Lead & Persuade', type: 'E', alt: 'Managing and influencing' },
    { img: '📊', text: 'Organize & Plan', type: 'C', alt: 'Structured and detailed work' },
    { img: '⚙️', text: 'Hands-On Projects', type: 'R', alt: 'Practical work' },
    { img: '🧪', text: 'Experiment & Discover', type: 'I', alt: 'Scientific thinking' },
    { img: '✍️', text: 'Write & Express', type: 'A', alt: 'Creative expression' },
    { img: '👥', text: 'Collaborate & Support', type: 'S', alt: 'Teamwork' },
    { img: '🎯', text: 'Set Goals & Achieve', type: 'E', alt: 'Results-driven' },
    { img: '📋', text: 'Follow Systems', type: 'C', alt: 'Process-oriented' }
  ];

  const riasecTypes = {
    R: { name: 'Realistic (Doer)', roles: 'Engineer, Developer, Technician', color: 'bg-blue-500' },
    I: { name: 'Investigative (Thinker)', roles: 'Data Scientist, Researcher, Analyst', color: 'bg-purple-500' },
    A: { name: 'Artistic (Creator)', roles: 'Designer, Content Creator, UX/UI', color: 'bg-pink-500' },
    S: { name: 'Social (Helper)', roles: 'Teacher, HR, Customer Success', color: 'bg-green-500' },
    E: { name: 'Enterprising (Persuader)', roles: 'Manager, Sales, Product Manager', color: 'bg-orange-500' },
    C: { name: 'Conventional (Organizer)', roles: 'Accountant, Admin, Operations', color: 'bg-gray-500' }
  };

  // Start Personality Test
  const startTestBtn = document.getElementById('startPersonalityTest');
  const industrySelect = document.getElementById('industry');
  const roleSelect = document.getElementById('targetRole');
  const expInput = document.querySelector('[name="yearsOfExperience"]');

  // Enable quiz button only when all required fields are filled
  function checkQuizAvailability() {
    const canTakeQuiz = isUserIdValid && 
                        expInput.value && 
                        industrySelect.value && 
                        roleSelect.value;
    
    if (canTakeQuiz) {
      startTestBtn.disabled = false;
      startTestBtn.classList.remove('bg-slate-600', 'text-slate-400', 'cursor-not-allowed');
      startTestBtn.classList.add('bg-sky-500', 'hover:bg-sky-600', 'text-white');
    } else {
      startTestBtn.disabled = true;
      startTestBtn.classList.remove('bg-sky-500', 'hover:bg-sky-600', 'text-white');
      startTestBtn.classList.add('bg-slate-600', 'text-slate-400', 'cursor-not-allowed');
    }
  }

  userIdInput.addEventListener('input', checkQuizAvailability);
  expInput.addEventListener('input', checkQuizAvailability);
  industrySelect.addEventListener('change', checkQuizAvailability);
  roleSelect.addEventListener('change', checkQuizAvailability);

  startTestBtn.addEventListener('click', function() {
    if (!this.disabled) showPersonalityModal();
  });

  function showPersonalityModal() {
    const targetRole = roleSelect.value;
    const industry = industrySelect.value;
    const years = expInput.value;
    
    // Reset scores
    personalityScores = { R: 0, I: 0, A: 0, S: 0, E: 0, C: 0 };
    
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-gray-950/95 z-50 flex items-center justify-center p-4';
    modal.innerHTML = `
      <div class="max-w-4xl w-full">
        <div class="glass-card rounded-2xl p-8 border border-slate-700">
          <div class="text-center mb-8">
            <h2 class="text-3xl font-bold text-white mb-2">Personalize Your ${targetRole} Roadmap</h2>
            <p class="text-slate-400">For ${industry} • ${years} years experience • Select activities you enjoy</p>
            <div class="mt-4 flex justify-center gap-2">
              ${Array(12).fill(0).map((_, i) => `<div class="w-2 h-2 rounded-full bg-slate-700" id="progress-${i}"></div>`).join('')}
            </div>
          </div>
          <div id="questionContainer" class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6">
            ${personalityQuestions.map((q, i) => `
              <button type="button" onclick="selectActivity(${i}, '${q.type}')" 
                      class="activity-card p-6 bg-slate-800/60 hover:bg-slate-700/60 border-2 border-slate-700 hover:border-sky-500 rounded-xl transition-all duration-200 text-center group">
                <div class="text-5xl mb-3">${q.img}</div>
                <p class="text-white font-medium text-sm group-hover:text-sky-300">${q.text}</p>
              </button>
            `).join('')}
          </div>
          <div class="flex justify-between items-center">
            <button type="button" onclick="closePersonalityModal()" class="px-6 py-2 text-slate-400 hover:text-white transition-colors">
              Skip for now
            </button>
            <div class="flex flex-col items-end">
              <p id="selectionError" class="text-xs text-red-400 mb-2 hidden">Please select at least 6 activities</p>
              <button type="button" id="finishTest" onclick="attemptFinish()" class="px-6 py-3 bg-slate-600 hover:bg-slate-700 text-white font-semibold rounded-xl transition-colors">
                See My Results
              </button>
            </div>
          </div>
        </div>
      </div>
    `;
    document.body.appendChild(modal);
    window.currentModal = modal;
    window.selectedCount = 0;
  }

  window.selectActivity = function(index, type) {
    const progress = document.getElementById(`progress-${index}`);
    const card = event.currentTarget;
    
    if (progress.classList.contains('bg-sky-500')) {
      // Deselect
      progress.classList.remove('bg-sky-500');
      progress.classList.add('bg-slate-700');
      card.classList.remove('border-sky-500', 'bg-sky-500/20');
      card.classList.add('border-slate-700');
      personalityScores[type]--;
      window.selectedCount--;
    } else {
      // Select
      progress.classList.remove('bg-slate-700');
      progress.classList.add('bg-sky-500');
      card.classList.remove('border-slate-700');
      card.classList.add('border-sky-500', 'bg-sky-500/20');
      personalityScores[type]++;
      window.selectedCount++;
    }
    
    // Enable finish button if at least 6 selected
    const finishBtn = document.getElementById('finishTest');
    if (window.selectedCount >= 6) {
      finishBtn.classList.remove('bg-slate-600', 'hover:bg-slate-700');
      finishBtn.classList.add('bg-sky-500', 'hover:bg-sky-600');
    } else {
      finishBtn.classList.remove('bg-sky-500', 'hover:bg-sky-600');
      finishBtn.classList.add('bg-slate-600', 'hover:bg-slate-700');
    }
  };

  window.attemptFinish = function() {
    if (window.selectedCount < 6) {
      const errorMsg = document.getElementById('selectionError');
      const btn = document.getElementById('finishTest');
      errorMsg.classList.remove('hidden');
      btn.classList.add('animate-shake');
      setTimeout(() => {
        btn.classList.remove('animate-shake');
        errorMsg.classList.add('hidden');
      }, 2000);
      return;
    }
    finishPersonalityTest();
  };

  window.finishPersonalityTest = function() {
    // Calculate top 2 types
    const sorted = Object.entries(personalityScores)
      .sort((a, b) => b[1] - a[1])
      .filter(([_, score]) => score > 0)
      .slice(0, 2);
    
    if (sorted.length === 0) return;
    
    const primaryType = sorted[0][0];
    const secondaryType = sorted.length > 1 ? sorted[1][0] : null;
    
    const result = secondaryType 
      ? `${riasecTypes[primaryType].name} + ${riasecTypes[secondaryType].name}`
      : riasecTypes[primaryType].name;
    
    // Show personality type and target role context
    const targetRole = roleSelect.value;
    const industry = industrySelect.value;
    
    // Show result
    document.getElementById('personalityType').textContent = `${result} • Tailored for ${targetRole} in ${industry}`;
    document.getElementById('personalityResult').classList.remove('hidden');
    document.getElementById('personalityTypeInput').value = `${primaryType}${secondaryType ? '-' + secondaryType : ''}`;
    document.getElementById('startPersonalityTest').textContent = 'Retake Quiz';
    document.getElementById('startPersonalityTest').classList.remove('bg-sky-500', 'hover:bg-sky-600');
    document.getElementById('startPersonalityTest').classList.add('bg-slate-800', 'hover:bg-slate-700', 'text-white');;
    
    closePersonalityModal();
  };

  window.closePersonalityModal = function() {
    if (window.currentModal) {
      window.currentModal.remove();
      window.currentModal = null;
    }
  };

  // Real-time userId validation
  userIdInput.addEventListener('input', function() {
    const value = this.value;
    const isValid = /^[a-zA-Z0-9_-]*$/.test(value);
    
    // Hide all messages first
    userIdError.classList.add('hidden');
    userIdExists.classList.add('hidden');
    userIdAvailable.classList.add('hidden');
    
    if (!isValid && value.length > 0) {
      userIdError.classList.remove('hidden');
      this.classList.add('border-red-500');
      this.classList.remove('border-slate-700');
      isUserIdValid = false;
    } else if (value.length >= 3) {
      this.classList.remove('border-red-500');
      this.classList.add('border-slate-700');
      
      // Debounce the uniqueness check
      clearTimeout(checkTimeout);
      checkTimeout = setTimeout(async () => {
        try {
          const response = await fetch(`/Resume/CheckUserId?userId=${encodeURIComponent(value)}`);
          const result = await response.json();
          
          if (result.exists) {
            userIdExists.classList.remove('hidden');
            document.getElementById('goToTracker').href = `/Roadmap/Tracker?userId=${encodeURIComponent(value)}`;
            userIdInput.classList.add('border-amber-500');
            userIdInput.classList.remove('border-slate-700');
            isUserIdValid = false;
          } else {
            userIdAvailable.classList.remove('hidden');
            userIdInput.classList.remove('border-amber-500');
            userIdInput.classList.add('border-slate-700');
            isUserIdValid = true;
          }
        } catch (error) {
          console.error('Error checking userId:', error);
        }
      }, 500);
    } else {
      this.classList.remove('border-red-500', 'border-amber-500');
      this.classList.add('border-slate-700');
      isUserIdValid = false;
    }
  });

  // Industry to roles mapping by experience level
  const rolesByIndustryAndExp = {
    'IT': {
      junior: ['Junior Software Engineer', 'Associate Developer', 'Junior DevOps Engineer', 'Junior Data Analyst', 'QA Engineer', 'Technical Support Engineer', 'Junior ML Engineer', 'SOC Analyst', 'Junior Data Scientist'],
      mid: ['Software Engineer', 'Cloud Engineer', 'DevOps Engineer', 'Data Engineer', 'Full Stack Developer', 'Backend Developer', 'Frontend Developer', 'Security Engineer', 'Machine Learning Engineer', 'AI Engineer', 'Data Scientist', 'Cybersecurity Analyst', 'Penetration Tester', 'NLP Engineer', 'Computer Vision Engineer'],
      senior: ['Senior Software Engineer', 'Senior Cloud Architect', 'Senior DevOps Engineer', 'Lead Developer', 'Principal Engineer', 'Staff Engineer', 'Senior ML Engineer', 'Senior Data Scientist', 'Lead Security Architect', 'Principal Security Engineer'],
      leadership: ['Engineering Manager', 'Technical Director', 'VP of Engineering', 'CTO', 'Solutions Architect', 'Enterprise Architect', 'Head of AI', 'VP of Data Science', 'CISO', 'Director of Security']
    },
    'Healthcare': {
      junior: ['Healthcare Coordinator', 'Clinical Assistant', 'Junior Healthcare Analyst'],
      mid: ['Healthcare Administrator', 'Clinical Manager', 'Healthcare IT Specialist', 'Nurse Practitioner'],
      senior: ['Senior Healthcare Administrator', 'Senior Clinical Manager', 'Healthcare Consultant'],
      leadership: ['Medical Director', 'Chief Medical Officer', 'VP of Healthcare Operations', 'Healthcare Executive']
    },
    'Finance': {
      junior: ['Junior Financial Analyst', 'Associate Analyst', 'Junior Accountant'],
